<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Pulse — ADHD-Savvy News Dashboard</title>
<style>
  /* ─── ADHD-SAVVY DESIGN SYSTEM ─── */
  :root {
    --bg: #0b0d11;
    --panel: #141820;
    --surface: #1a1f29;
    --text: #f2f4f7;
    --muted: #8b95a5;
    --accent: #eab308;
    --accent2: #22c55e;
    --danger: #f87171;
    --info: #60a5fa;
    --border: #262c36;
    --radius: 12px;
    --radius-sm: 8px;
    --transition: 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --font: 'Inter', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', Roboto, sans-serif;
    --gap: 16px;
    --focus-glow: 0 0 20px rgba(234,179,8,0.15);
    --card-hover: 0 4px 24px rgba(0,0,0,0.3);
  }
  /* Energy Mode: low-spoon overrides */
  .energy-low {
    --text: #e8eaed;
    --muted: #9aa0a6;
    --surface: #1e1e1e;
    --panel: #121212;
    --border: #333;
    font-size: 18px;
    line-height: 1.7;
  }
  .energy-low .grid { grid-template-columns: 1fr; }
  .energy-low .news { max-height: none; }
  .energy-low .item a { font-size: 17px; }
  .energy-low .snippet { font-size: 15px; }
  .energy-low .pill { font-size: 15px; padding: 10px 16px; flex-shrink: 0; white-space: nowrap; }

  * { box-sizing: border-box; margin: 0; padding: 0; }
  html { min-height: 100%; }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: var(--font);
    background: var(--bg);
    color: var(--text);
    transition: background var(--transition), color var(--transition);
    -webkit-font-smoothing: antialiased;
    display: flex;
    flex-direction: column;
  }
  ::selection { background: var(--accent); color: #000; }

  /* ─── DOPAMINE ANIMATIONS ─── */
  @keyframes fadeSlideUp {
    from { opacity: 0; transform: translateY(16px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes popIn {
    0% { transform: scale(0.8); opacity: 0; }
    70% { transform: scale(1.05); }
    100% { transform: scale(1); opacity: 1; }
  }
  @keyframes pulse {
    0% { opacity: 1; box-shadow: 0 0 0 0 rgba(248,113,113,0.45); }
    70% { opacity: .85; box-shadow: 0 0 0 14px rgba(248,113,113,0); }
    100% { opacity: 1; box-shadow: 0 0 0 0 rgba(248,113,113,0); }
  }
  @keyframes breaking-glow {
    0%, 100% { box-shadow: 0 0 18px rgba(248,113,113,0.18); border-color: rgba(248,113,113,0.55); }
    50% { box-shadow: 0 0 40px rgba(248,113,113,0.55); border-color: rgba(251,146,60,0.85); }
  }
  @keyframes streakGlow {
    0%, 100% { box-shadow: 0 0 8px rgba(234,179,8,0.3); }
    50% { box-shadow: 0 0 24px rgba(234,179,8,0.6); }
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }
  @keyframes confettiFall {
    0% { transform: translateY(-100vh) rotate(0deg); opacity: 1; }
    100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
  }
  @keyframes badgePop {
    0% { transform: scale(0); }
    60% { transform: scale(1.2); }
    100% { transform: scale(1); }
  }
  @keyframes ripple {
    0% { box-shadow: 0 0 0 0 rgba(234,179,8,0.4); }
    100% { box-shadow: 0 0 0 20px rgba(234,179,8,0); }
  }
  .card, .break-tile, .gamification-panel { animation: fadeSlideUp 0.4s ease forwards; }
  .card:nth-child(1) { animation-delay: 0.05s; }
  .card:nth-child(2) { animation-delay: 0.1s; }
  .card:nth-child(3) { animation-delay: 0.15s; }
  .card:nth-child(4) { animation-delay: 0.2s; }
  .card:nth-child(5) { animation-delay: 0.25s; }
  .card:nth-child(6) { animation-delay: 0.3s; }
  .break-tile { animation: popIn 0.35s ease forwards; }

  /* ─── HEADER ─── */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(11,13,17,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border);
    padding: 10px 16px;
  }
.bar {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    min-width: 0;
    flex-wrap: wrap;
  }
  .brand { font-weight: 800; font-size: 18px; letter-spacing: -0.5px; display: flex; align-items: center; gap: 8px; flex-shrink: 0; }
  .brand-logo { color: var(--accent); }
  .brand-sub { color: var(--muted); font-weight: 400; font-size: 12px; }
  .header-actions { display: flex; gap: 6px; align-items: center; flex-wrap: wrap; flex-shrink: 0; }
  .pills {
    display: flex;
    gap: 6px;
    overflow-x: auto;
    flex-wrap: nowrap;
    padding-bottom: 4px;
    scrollbar-width: thin;
    flex: 1 1 0;
    min-width: 0;
    max-width: 760px;
  }
  .pills::-webkit-scrollbar { height: 4px; }
  .pills::-webkit-scrollbar-track { background: transparent; }
  .pills::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 999px; }
  .pill {
    font-size: 12px;
    padding: 6px 12px;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    transition: all var(--transition);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .pill:hover { border-color: var(--accent); color: var(--text); }
  .pill.active { background: var(--accent); color: #000; border-color: var(--accent); font-weight: 600; }

  /* ─── TOOLBAR ─── */
  .toolbar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 8px 16px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .toolbar-left { display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .toolbar-right { display: flex; gap: 8px; align-items: center; }
  .tool-btn {
    font-size: 12px;
    padding: 6px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    cursor: pointer;
    transition: all var(--transition);
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tool-btn:hover { border-color: var(--accent); color: var(--text); background: rgba(234,179,8,0.08); }
  .tool-btn.active { border-color: var(--accent2); color: var(--accent2); background: rgba(34,197,94,0.1); }
  .tool-btn.primary { border-color: var(--accent); color: var(--accent); background: rgba(234,179,8,0.1); }
  .tool-btn.primary:hover { background: rgba(234,179,8,0.2); }
  .status-line { color: var(--muted); font-size: 12px; }
  #clockLine { color: var(--muted); font-size: 12px; font-variant-numeric: tabular-nums; }

  /* ─── GAMIFICATION BAR ─── */
  .gamification-bar {
    max-width: 1200px;
    margin: 0 auto;
    padding: 6px 16px;
    display: flex;
    gap: 16px;
    align-items: center;
    flex-wrap: wrap;
  }
  .gamification-bar.hidden { display: none; }
  .stat-badge {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 12px;
    color: var(--muted);
    padding: 4px 10px;
    border-radius: 999px;
    background: var(--surface);
    border: 1px solid var(--border);
  }
  .stat-badge.highlight { border-color: var(--accent); color: var(--accent); animation: streakGlow 2s infinite; }
  .stat-badge .num { font-weight: 700; font-size: 14px; }
  .xp-bar-wrap { flex: 1; min-width: 80px; max-width: 200px; height: 6px; background: var(--border); border-radius: 999px; overflow: hidden; }
  .xp-bar-fill { height: 100%; background: linear-gradient(90deg, var(--accent), var(--accent2)); border-radius: 999px; transition: width 0.5s ease; width: 0%; }
  .daily-goal { display: flex; align-items: center; gap: 6px; font-size: 11px; color: var(--muted); }
  .daily-goal .progress { flex: 1; min-width: 60px; height: 4px; background: var(--border); border-radius: 999px; overflow: hidden; }
  .daily-goal .fill { height: 100%; background: var(--accent2); border-radius: 999px; transition: width 0.5s; }

  /* ─── CONFETTI CONTAINER ─── */
  #confetti-container { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; z-index: 9999; overflow: hidden; }
  .confetti-piece {
    position: absolute;
    width: 10px;
    height: 10px;
    animation: confettiFall 3s ease-in forwards;
  }

  /* ─── POMODORO ─── */
  .pomodoro-wrap { position: relative; }
  .pomodoro-panel {
    display: none;
    position: absolute;
    top: 100%;
    right: 0;
    margin-top: 6px;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    min-width: 220px;
    z-index: 200;
    box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .pomodoro-panel.open { display: block; animation: fadeSlideUp 0.2s ease; }
  .pomodoro-display { font-size: 36px; font-weight: 800; text-align: center; font-variant-numeric: tabular-nums; letter-spacing: 2px; color: var(--text); }
  .pomodoro-label { text-align: center; font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 8px; }
  .pomodoro-controls { display: flex; gap: 6px; justify-content: center; margin-top: 10px; }
  .pomodoro-controls button {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    transition: all var(--transition);
  }
  .pomodoro-controls button:hover { border-color: var(--accent); }
  .pomodoro-controls button.primary { background: var(--accent); color: #000; border-color: var(--accent); }

  /* ─── TUTOR PANEL ─── */
  .tutor-panel {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(480px, 92vw);
    max-height: 80vh;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    z-index: 300;
    box-shadow: 0 16px 64px rgba(0,0,0,0.6);
    overflow-y: auto;
    animation: fadeSlideUp 0.25s ease;
  }
  .tutor-panel.open { display: block; }
  .tutor-panel h3 { font-size: 16px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
  .tutor-panel .close-btn {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--muted);
    font-size: 18px;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .tutor-panel .close-btn:hover { color: var(--text); background: var(--surface); }
  .tutor-tabs { display: flex; gap: 4px; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
  .tutor-tab {
    flex: 1;
    padding: 8px;
    text-align: center;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 13px;
    transition: all var(--transition);
  }
  .tutor-tab.active { background: var(--surface); color: var(--text); border-color: var(--border); }
  .tutor-tab:hover { color: var(--text); }
  .tutor-content { display: none; }
  .tutor-content.active { display: block; animation: fadeSlideUp 0.3s ease; }
  .csat-question { font-size: 15px; line-height: 1.6; margin-bottom: 16px; padding: 12px; background: var(--surface); border-radius: var(--radius-sm); border-left: 3px solid var(--info); }
  .csat-options { display: flex; flex-direction: column; gap: 8px; margin-bottom: 12px; }
  .csat-option {
    padding: 10px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 14px;
    text-align: left;
    transition: all var(--transition);
  }
  .csat-option:hover { border-color: var(--accent); background: rgba(234,179,8,0.08); }
  .csat-option.selected { border-color: var(--info); background: rgba(96,165,250,0.12); }
  .csat-option.correct { border-color: var(--accent2); background: rgba(34,197,94,0.15); }
  .csat-option.wrong { border-color: var(--danger); background: rgba(248,113,113,0.15); }
  .csat-option:disabled { cursor: default; opacity: 0.8; }
  .csat-result { padding: 10px; border-radius: var(--radius-sm); margin-top: 8px; font-size: 13px; line-height: 1.5; }
  .csat-result.correct { background: rgba(34,197,94,0.12); border: 1px solid rgba(34,197,94,0.3); }
  .csat-result.wrong { background: rgba(248,113,113,0.12); border: 1px solid rgba(248,113,113,0.3); }
  .csat-controls { display: flex; gap: 8px; margin-top: 12px; }
  .csat-controls button {
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    transition: all var(--transition);
  }
  .csat-controls button:hover { border-color: var(--accent); }
  .csat-controls button.primary { background: var(--accent); color: #000; border-color: var(--accent); }
  .csat-stats { font-size: 12px; color: var(--muted); margin-top: 12px; display: flex; gap: 12px; flex-wrap: wrap; }
  .csat-stats span { background: var(--surface); padding: 4px 10px; border-radius: var(--radius-sm); }
  .psych-card {
    padding: 14px;
    background: var(--surface);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--accent2);
    margin-bottom: 12px;
  }
  .psych-card h4 { font-size: 15px; margin-bottom: 6px; color: var(--accent); }
  .psych-card p { font-size: 13px; line-height: 1.6; color: var(--text); }
  .psych-card .tags { margin-top: 8px; display: flex; gap: 4px; flex-wrap: wrap; }
  .psych-card .tags span { font-size: 11px; padding: 2px 8px; background: rgba(34,197,94,0.12); border-radius: 10px; color: var(--accent2); }
  .psych-nav { display: flex; gap: 8px; justify-content: space-between; align-items: center; margin-top: 12px; }
  .psych-nav button {
    padding: 6px 14px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    transition: all var(--transition);
  }
  .psych-nav button:hover { border-color: var(--accent2); }
  .psych-nav span { font-size: 12px; color: var(--muted); }
  .tutor-mode-badge { font-size: 11px; padding: 2px 8px; border-radius: 10px; background: rgba(234,179,8,0.15); color: var(--accent); margin-left: 6px; }

  /* ─── BREAKING NEWS ─── */
  .breaking {
    max-width: 1200px;
    margin: 0 auto 6px;
    padding: 0 16px;
  }
  .breaking-wrapper {
    position: relative;
    background: linear-gradient(135deg, rgba(248,113,113,0.28) 0%, rgba(248,113,113,0.10) 60%, rgba(251,146,60,0.16) 100%);
    border: 2px solid rgba(248,113,113,0.80);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 0 60px rgba(248,113,113,0.45);
    animation: breaking-glow 2s ease-in-out infinite;
  }
  .breaking-wrapper::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.12), transparent);
    background-size: 300% 100%;
    animation: shimmer 3.2s linear infinite;
    pointer-events: none;
  }
  .breaking-board { display: grid; grid-template-columns: 1fr; }
  .breaking-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 10px;
    padding: 12px 16px;
    border-bottom: 1px solid rgba(248,113,113,0.50);
    background: linear-gradient(90deg, rgba(248,113,113,0.28) 0%, rgba(251,146,60,0.18) 100%);
  }
  .breaking-brand { display: flex; align-items: center; gap: 10px; font-weight: 800; font-size: 18px; letter-spacing: 0.3px; }
  .breaking-live {
    padding: 4px 10px;
    border-radius: 999px;
    background: rgba(248,113,113,0.35);
    color: #ffe4e4;
    font-size: 11px;
    font-weight: 700;
    border: 1px solid rgba(255,255,255,0.25);
    animation: pulse 1.2s infinite;
    box-shadow: 0 0 12px rgba(248,113,113,0.55);
  }
  .breaking-pills { display: flex; gap: 6px; overflow-x: auto; flex-wrap: nowrap; justify-content: flex-start; padding-bottom: 4px; scrollbar-width: thin; }
  .source-chip {
    padding: 4px 8px;
    border-radius: 999px;
    background: rgba(234,179,8,0.18);
    color: #fde68a;
    font-size: 10px;
    border: 1px solid rgba(250,204,21,0.55);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .breaking-pills::-webkit-scrollbar { height: 4px; }
  .breaking-pills::-webkit-scrollbar-track { background: transparent; }
  .breaking-pills::-webkit-scrollbar-thumb { background: rgba(248,113,113,0.35); border-radius: 999px; }
  .breaking-pills::-webkit-scrollbar { height: 4px; }
  .breaking-pills::-webkit-scrollbar-track { background: transparent; }
  .breaking-pills::-webkit-scrollbar-thumb { background: rgba(248,113,113,0.35); border-radius: 999px; }
  .breaking-body { padding: 12px; }
  .breaking-lead {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 10px;
  }
  @media (max-width: 900px) { .breaking-lead { grid-template-columns: 1fr; } }
  .break-tile {
    background: linear-gradient(180deg, rgba(26,31,41,0.98) 0%, rgba(20,24,32,0.98) 100%);
    border: 1px solid rgba(248,113,113,0.75);
    border-radius: 12px;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: all var(--transition);
  }
  .break-tile:hover { transform: translateY(-3px) scale(1.02); box-shadow: 0 0 42px rgba(248,113,113,0.55); border-color: rgba(251,146,60,0.95); }
  .break-tile--hot { border-left: 4px solid #ff4d4f; box-shadow: inset 8px 0 14px -10px rgba(255,77,79,0.55); }
  .break-tile--warn { border-left: 4px solid #ff922b; box-shadow: inset 8px 0 14px -10px rgba(255,146,43,0.55); }
  .break-tile--info { border-left: 4px solid #facc15; box-shadow: inset 8px 0 14px -10px rgba(250,204,21,0.45); }
  .break-rank { display: flex; align-items: flex-start; gap: 8px; }
  .rank-badge {
    padding: 3px 7px;
    border-radius: 8px;
    font-size: 11px;
    font-weight: 800;
    min-width: 24px;
    text-align: center;
    box-shadow: 0 0 10px rgba(0,0,0,0.45);
  }
  .rank-hot { background: rgba(248,113,113,.28); color: #ffe4e4; border: 1px solid rgba(248,113,113,.85); box-shadow: 0 0 14px rgba(248,113,113,.55); }
  .rank-warn { background: rgba(251,146,60,.28); color: #fff1e6; border: 1px solid rgba(251,146,60,.85); box-shadow: 0 0 14px rgba(251,146,60,.55); }
  .rank-info { background: rgba(250,204,21,.28); color: #fff7c2; border: 1px solid rgba(250,204,21,.85); box-shadow: 0 0 14px rgba(250,204,21,.50); }
  .break-title { color: #ffffff; text-decoration: none; font-weight: 800; line-height: 1.42; font-size: 15px; text-shadow: 0 0 14px rgba(248,113,113,0.4); }
  .break-title:hover { color: var(--accent); }
  .break-snippet { color: #dbeafe; font-size: 12px; line-height: 1.55; }
  .break-rail { margin-top: 12px; display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; }
  @media (max-width: 900px) { .break-rail { grid-template-columns: 1fr; } }
  .break-rail-title {
    grid-column: 1 / -1;
    font-size: 11px;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.6px;
  }
  .break-rail-item {
    display: grid;
    grid-template-columns: 14px 1fr;
    gap: 8px;
    padding: 8px;
    border-radius: 8px;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    text-decoration: none;
    transition: all var(--transition);
  }
  .break-rail-item:hover { border-color: var(--accent); background: rgba(234,179,8,0.05); }
  .break-rail-pulse {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--danger); box-shadow: 0 0 8px rgba(248,113,113,0.80);
    justify-self: center; align-self: center;
  }
  .break-rail-text { font-weight: 600; line-height: 1.35; font-size: 13px; }
  .break-rail-meta { grid-column: 2; color: var(--muted); font-size: 11px; }

  /* ─── MAIN GRID ─── */
  main { max-width: 1200px; margin: 0 auto; padding: 8px 16px 40px; }
  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: var(--gap);
  }
  @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

  /* ─── FOCUS MODE ─── */
  .focus-mode .news { max-height: none; }
  .focus-mode .item a { font-size: 16px; }
  .focus-mode .snippet { display: none; }
  .focus-mode .meta { font-size: 11px; color: var(--muted); }
  .focus-mode .card { border-left: 3px solid var(--accent); }
  .focus-mode .breaking-wrapper { display: none; }

  /* ─── UPSC LENS ─── */
  .upsc-lens .card.upsc-high { border-left: 4px solid var(--accent2); order: -1; }
  .upsc-lens .card.upsc-med { border-left: 4px solid var(--accent); }
  .upsc-lens .grid { display: flex; flex-direction: column; }
  .upsc-tag {
    display: inline-block;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    background: rgba(34,197,94,0.15);
    color: var(--accent2);
    border: 1px solid rgba(34,197,94,0.3);
    margin-right: 4px;
  }

  /* ─── CARDS ─── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 14px;
    transition: all var(--transition);
  }
  .card:hover { border-color: rgba(234,179,8,0.3); box-shadow: var(--card-hover); }
  .topic-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
  }
  .topic-title { font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 6px; }
  .topic-count {
    font-size: 11px;
    color: var(--accent2);
    background: rgba(34,197,94,0.12);
    padding: 3px 8px;
    border-radius: 999px;
  }
  .news {
    display: flex;
    flex-direction: column;
    gap: 10px;
    max-height: 55vh;
    overflow-y: auto;
    padding-right: 6px;
  }
  .news::-webkit-scrollbar { width: 4px; }
  .news::-webkit-scrollbar-track { background: transparent; }
  .news::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  .item {
    padding: 8px;
    border-radius: var(--radius-sm);
    transition: all var(--transition);
    border: 1px solid transparent;
  }
  .item:hover { background: rgba(255,255,255,0.03); border-color: var(--border); }
  .item a {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.4;
    display: block;
  }
  .item a:hover { color: var(--accent); }
  .meta { color: var(--muted); font-size: 11px; margin-top: 4px; display: flex; gap: 8px; align-items: center; flex-wrap: wrap; }
  .meta-sep { opacity: 0.3; }
  .snippet {
    color: var(--muted);
    font-size: 12px;
    line-height: 1.45;
    margin-top: 4px;
  }
  .item-actions { display: flex; gap: 4px; margin-top: 6px; }
  .item-action {
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 6px;
    border: 1px solid var(--border);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all var(--transition);
  }
  .item-action:hover { border-color: var(--accent); color: var(--accent); }
  .item-action.saved { border-color: var(--accent2); color: var(--accent2); background: rgba(34,197,94,0.1); }
  .item-action.listened { border-color: var(--info); color: var(--info); background: rgba(96,165,250,0.1); }
  .empty { color: var(--muted); font-size: 12px; padding: 12px; text-align: center; }

  /* ─── SEARCH ─── */
  .search-box {
    display: flex;
    align-items: center;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 4px 12px;
    gap: 6px;
    transition: all var(--transition);
  }
  .search-box:focus-within { border-color: var(--accent); box-shadow: var(--focus-glow); }
  .search-box input {
    background: none;
    border: none;
    color: var(--text);
    font-size: 13px;
    outline: none;
    width: 120px;
    font-family: var(--font);
  }
  .search-box input::placeholder { color: var(--muted); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    .bar { flex-direction: column; align-items: stretch; }
    .pills { justify-content: center; }
    .toolbar { flex-direction: column; align-items: stretch; }
    .toolbar-left { justify-content: center; }
    .toolbar-right { justify-content: center; }
    .gamification-bar { justify-content: center; }
    .search-box input { width: 80px; }
    .pomodoro-panel { right: -40px; }
  }

  /* ─── BOOKMARKS PANEL ─── */
  .bookmarks-panel {
    display: none;
    position: fixed;
    top: 0;
    right: 0;
    width: 360px;
    max-width: 90vw;
    height: 100vh;
    background: var(--panel);
    border-left: 1px solid var(--border);
    z-index: 300;
    overflow-y: auto;
    padding: 20px 16px;
    box-shadow: -8px 0 32px rgba(0,0,0,0.4);
  }
  .bookmarks-panel.open { display: block; animation: fadeSlideUp 0.25s ease; }
  .bookmarks-panel h3 { font-size: 16px; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
  .bookmarks-panel .close-btn {
    margin-left: auto;
    background: none;
    border: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 18px;
    padding: 4px;
  }
  .bookmark-item {
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    margin-bottom: 8px;
    background: var(--surface);
  }
  .bookmark-item a { color: var(--text); text-decoration: none; font-weight: 600; font-size: 13px; }
  .bookmark-item a:hover { color: var(--accent); }
  .bookmark-meta { font-size: 11px; color: var(--muted); margin-top: 4px; }
  .bookmark-remove {
    float: right;
    background: none;
    border: none;
    color: var(--danger);
    cursor: pointer;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 4px;
  }
  .bookmark-remove:hover { background: rgba(248,113,113,0.1); }
  .bookmarks-empty { color: var(--muted); font-size: 13px; text-align: center; padding: 40px 0; }

  /* ─── FEED MANAGER ─── */
  .feed-panel {
    display: none;
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(680px, 94vw);
    max-height: 85vh;
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    z-index: 300;
    box-shadow: 0 16px 64px rgba(0,0,0,0.6);
    overflow-y: auto;
    animation: fadeSlideUp 0.25s ease;
  }
  .feed-panel.open { display: block; }
  .feed-panel-header { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .feed-panel-header h3 { font-size: 16px; flex: 1; }
  .feed-panel-header .close-btn {
    background: none;
    border: none;
    color: var(--muted);
    font-size: 18px;
    cursor: pointer;
    padding: 4px 8px;
    border-radius: 4px;
  }
  .feed-panel-header .close-btn:hover { color: var(--text); background: var(--surface); }
  .feed-tabs { display: flex; gap: 4px; margin-bottom: 16px; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
  .feed-tab {
    flex: 1;
    padding: 8px;
    text-align: center;
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    font-size: 13px;
    transition: all var(--transition);
  }
  .feed-tab.active { background: var(--surface); color: var(--text); border-color: var(--border); }
  .feed-tab:hover { color: var(--text); }
  .feed-tab-content { display: none; }
  .feed-tab-content.active { display: block; animation: fadeSlideUp 0.3s ease; }
  .feed-add-form {
    display: flex;
    gap: 6px;
    margin-bottom: 16px;
    flex-wrap: wrap;
  }
  .feed-input {
    flex: 1;
    min-width: 120px;
    padding: 8px 12px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    font-size: 13px;
    font-family: var(--font);
    outline: none;
    transition: border var(--transition);
  }
  .feed-input:focus { border-color: var(--accent); }
  .feed-input::placeholder { color: var(--muted); }
  .feed-list { display: flex; flex-direction: column; gap: 4px; max-height: 50vh; overflow-y: auto; padding-right: 4px; }
  .feed-list::-webkit-scrollbar { width: 4px; }
  .feed-list::-webkit-scrollbar-track { background: transparent; }
  .feed-list::-webkit-scrollbar-thumb { background: var(--border); border-radius: 999px; }
  .feed-item {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 5px 9px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 999px;
    transition: all var(--transition);
    flex-shrink: 0;
    white-space: nowrap;
  }
  .feed-item:hover { border-color: rgba(234,179,8,0.2); }
  .feed-item.disabled { opacity: 0.5; }
  .feed-item-id { font-size: 11px; color: var(--accent); font-weight: 600; }
  .feed-item-url { font-size: 11px; color: var(--muted); overflow: hidden; text-overflow: ellipsis; max-width: 120px; white-space: nowrap; }
  .feed-item-label { font-size: 12px; color: var(--text); }
  .feed-item-query { font-size: 11px; color: var(--info); overflow: hidden; text-overflow: ellipsis; max-width: 100px; white-space: nowrap; }
  .feed-toggle {
    position: relative;
    width: 36px;
    height: 20px;
    flex-shrink: 0;
    background: var(--border);
    border-radius: 999px;
    cursor: pointer;
    transition: background var(--transition);
    border: none;
    padding: 0;
  }
  .feed-toggle.on { background: var(--accent2); }
  .feed-toggle::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 2px;
    width: 16px;
    height: 16px;
    background: #fff;
    border-radius: 999px;
    transition: transform var(--transition);
  }
  .feed-toggle.on::after { transform: translateX(16px); }
  .feed-remove-btn {
    background: none;
    border: none;
    color: var(--danger);
    cursor: pointer;
    font-size: 14px;
    padding: 2px 6px;
    border-radius: 4px;
    opacity: 0.6;
    transition: all var(--transition);
  }
  .feed-remove-btn:hover { opacity: 1; background: rgba(248,113,113,0.1); }
  .feed-loading { color: var(--muted); font-size: 13px; text-align: center; padding: 24px; }
  .feed-actions { margin-top: 16px; padding-top: 12px; border-top: 1px solid var(--border); display: flex; gap: 8px; }
  .feed-success { color: var(--accent2); font-size: 12px; padding: 4px 0; }
  .feed-error { color: var(--danger); font-size: 12px; padding: 4px 0; }

  /* ─── TTS TOAST ─── */
  .tts-toast {
    display: none;
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 12px 20px;
    z-index: 400;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    align-items: center;
    gap: 12px;
    max-width: 90vw;
  }
  .tts-toast.open { display: flex; animation: fadeSlideUp 0.25s ease; }
  .tts-toast .info { font-size: 13px; color: var(--text); overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 300px; }
  .tts-toast button {
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
    white-space: nowrap;
  }
  .tts-toast button:hover { border-color: var(--accent); }
  .tts-toast button.stop { border-color: var(--danger); color: var(--danger); }

  /* ─── FOCUS OVERLAY ─── */
  .focus-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.7);
    z-index: 50;
    cursor: pointer;
  }
  .focus-overlay.active { display: block; }

  /* ═══ ADHD FEATURES MODULE — Consolidated from all 6 agents ═══ */
  /* Productivity-OC · Social-Media-OC · Research-OC · Health-Therapy-OC · UPSC-OC · Maverick-OC */

  /* ─── ADHD DOCK ─── */
  .adhd-dock {
    max-width: 1200px; margin: 0 auto; padding: 6px 16px 2px;
    animation: fadeSlideUp 0.5s ease;
  }
  .adhd-row {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-bottom: 6px;
  }
  .adhd-widget {
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--surface);
    transition: all var(--transition);
  }
  .adhd-widget:hover { border-color: rgba(234,179,8,0.2); }
  .adhd-shield-bar {
    display: flex; gap: 6px; justify-content: flex-end;
    margin-bottom: 4px;
  }

  /* ─── 1. NEXT THING WIDGET ─── */
  .next-thing-widget {
    flex: 2; min-width: 220px;
    background: linear-gradient(135deg, rgba(234,179,8,0.08) 0%, rgba(234,179,8,0.02) 100%);
    border-color: rgba(234,179,8,0.25);
    cursor: default;
  }
  .next-thing-widget:hover { border-color: rgba(234,179,8,0.4); }
  .next-thing-inner {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
  }
  .next-thing-icon { font-size: 22px; flex-shrink: 0; }
  .next-thing-text {
    flex: 1; font-weight: 600; font-size: 13px;
    line-height: 1.35; color: var(--text);
  }
  .next-thing-action {
    font-size: 11px; color: var(--accent);
    white-space: nowrap; padding: 4px 10px;
    border-radius: 999px; background: rgba(234,179,8,0.12);
    font-weight: 600;
  }

  /* ─── 2. THREE-SECOND BUTTON ─── */
  .three-sec-widget {
    flex: 1; min-width: 160px;
  }
  .three-second-btn {
    width: 100%; padding: 10px 14px;
    background: linear-gradient(135deg, #eab308 0%, #f97316 100%);
    border: none; border-radius: 10px;
    cursor: pointer;
    display: flex; flex-direction: column; align-items: center; gap: 2px;
    transition: all 0.2s ease;
    animation: streakGlow 2.5s infinite;
  }
  .three-second-btn:hover {
    transform: scale(1.02);
    box-shadow: 0 4px 20px rgba(234,179,8,0.4);
  }
  .three-second-btn:active { transform: scale(0.98); }
  .ts-icon { font-size: 20px; }
  .ts-text {
    font-size: 14px; font-weight: 800; color: #000;
    letter-spacing: 1px;
  }
  .ts-sub {
    font-size: 9px; color: rgba(0,0,0,0.6); font-weight: 500;
  }
  .sprint-active {
    padding: 6px 10px; font-size: 11px; color: var(--accent2);
    display: flex; align-items: center; gap: 6px;
  }
  .sprint-pulse {
    color: var(--accent2);
    animation: pulse 1.5s infinite;
    font-size: 10px;
  }

  /* ─── 3. ENERGY WIDGET (Health-Therapy-OC) ─── */
  .energy-widget {
    flex: 1; min-width: 130px;
  }
  .energy-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 12px 0;
    font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px;
  }
  .energy-pct { font-size: 18px; font-weight: 800; color: var(--text); }
  .energy-track {
    margin: 4px 12px; height: 6px;
    background: rgba(255,255,255,0.08); border-radius: 999px; overflow: hidden;
  }
  .energy-fill {
    height: 100%; border-radius: 999px;
    background: linear-gradient(90deg, #ff4757, #ffa502, #2ed573);
    background-size: 200% 100%;
    animation: energyPulse 2.5s ease-in-out infinite;
    transition: width 0.8s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  @keyframes energyPulse {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }
  .energy-footer {
    padding: 2px 12px 8px;
    display: flex; justify-content: space-between;
  }
  .energy-mode-go { color: #2ed573; font-size: 11px; font-weight: 600; }
  .energy-mode-pace { color: #ffa502; font-size: 11px; font-weight: 600; }
  .energy-mode-rest { color: #ff4757; font-size: 11px; font-weight: 600; }

  /* ─── 4. STREAK FIRE ─── */
  .streak-widget {
    flex: 0 0 auto; min-width: 80px;
    display: flex; align-items: center; justify-content: center;
  }
  .streak-fire-wrap {
    display: flex; align-items: center; gap: 8px;
    padding: 6px 14px;
  }
  .streak-fire {
    font-size: 16px; transition: all 0.3s ease;
    filter: drop-shadow(0 0 6px rgba(234,179,8,0.3));
  }
  .streak-fire.hot {
    filter: drop-shadow(0 0 12px rgba(234,179,8,0.6));
    animation: streakGlow 2s infinite;
  }
  .streak-detail { display: flex; flex-direction: column; gap: 0; }
  .streak-num { font-weight: 800; font-size: 18px; line-height: 1; color: var(--accent); }
  .streak-level { font-size: 10px; color: var(--muted); }

  /* ─── 5. MICRO-GOAL ─── */
  .microgoal-widget {
    flex: 2; min-width: 280px;
  }
  .mg-header {
    display: flex; justify-content: space-between; align-items: center;
    padding: 8px 12px 4px;
    font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: 0.5px;
  }
  .mg-chain { font-size: 11px; color: var(--accent2); text-transform: none; letter-spacing: 0; }
  .mg-grid {
    display: flex; flex-wrap: wrap; gap: 4px;
    padding: 4px 12px 6px;
  }
  .mg-btn {
    padding: 5px 10px; border-radius: 999px;
    border: 1px solid var(--border);
    background: rgba(255,255,255,0.04);
    color: var(--text);
    font-size: 11px; cursor: pointer;
    transition: all var(--transition);
    font-family: var(--font);
  }
  .mg-btn:hover { border-color: var(--accent); background: rgba(234,179,8,0.1); }
  .mg-btn.mg-active {
    border-color: var(--accent);
    background: rgba(234,179,8,0.2);
    color: var(--accent);
  }
  .mg-btn.mg-done {
    opacity: 0.4; cursor: default;
    border-color: var(--accent2);
  }
  .mg-btn:disabled { cursor: default; }
  .mg-progress {
    padding: 0 12px 8px;
    font-size: 10px; color: var(--muted);
  }

  /* ─── 6. QUOTE ROTATOR ─── */
  .quote-widget {
    flex: 1; min-width: 200px;
    background: linear-gradient(135deg, rgba(96,165,250,0.06) 0%, rgba(167,139,250,0.04) 100%);
  }
  .quote-rotator {
    padding: 10px 14px;
    transition: opacity 0.3s ease;
  }
  .quote-text {
    font-size: 12px; font-style: italic; color: var(--muted);
    line-height: 1.5;
  }
  .quote-author {
    font-size: 10px; color: var(--info); margin-top: 4px;
    text-align: right;
  }

  /* ─── DIALOG OVERLAY ─── */
  .adhd-dialog-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.6);
    z-index: 9998;
    display: flex; align-items: center; justify-content: center;
    animation: fadeSlideUp 0.2s ease;
  }
  .adhd-dialog {
    background: var(--panel);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 24px;
    min-width: 300px; max-width: 420px;
    box-shadow: 0 16px 64px rgba(0,0,0,0.6);
  }
  .adhd-dialog-title {
    font-size: 18px; font-weight: 700;
    text-align: center; margin-bottom: 8px;
  }
  .adhd-dialog-body {
    font-size: 13px; color: var(--muted);
    text-align: center; line-height: 1.5; margin-bottom: 12px;
  }
  .adhd-dialog-btn {
    padding: 10px 24px; border-radius: var(--radius-sm);
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text); font-size: 13px;
    cursor: pointer; transition: all var(--transition);
    font-family: var(--font);
  }
  .adhd-dialog-btn:hover { border-color: var(--accent); }
  .adhd-dialog-btn.primary {
    background: var(--accent); color: #000;
    border-color: var(--accent); font-weight: 700;
  }
  .adhd-dialog-btn.primary:hover { background: #fbbf24; }

  /* ─── SPRINT DIALOG ─── */
  .sprint-dialog { text-align: center; }
  .sprint-badge {
    display: inline-block;
    padding: 4px 14px; border-radius: 999px;
    background: linear-gradient(135deg, #eab308, #f97316);
    color: #000; font-size: 11px; font-weight: 800;
    letter-spacing: 1px; margin-bottom: 12px;
  }
  .sprint-task {
    font-size: 18px; font-weight: 700; line-height: 1.4;
    margin-bottom: 16px;
  }
  .sprint-timer {
    font-size: 48px; font-weight: 800;
    font-variant-numeric: tabular-nums;
    color: var(--accent);
    letter-spacing: 4px;
  }
  .sprint-controls { display: flex; gap: 8px; justify-content: center; }

  /* ─── FOCUS SHIELD ─── */
  .focus-shield .adhd-row-top,
  .focus-shield .adhd-row-bottom { opacity: 0.15; transition: opacity 0.4s; pointer-events: none; }
  .focus-shield .adhd-shield-bar { opacity: 1; }
  .focus-shield .breaking-wrapper { opacity: 0.1; pointer-events: none; transition: opacity 0.4s; }
  .focus-shield .toolbar-left > *:not(#adhd-shield-btn):not(.pomodoro-wrap) { opacity: 0.2; pointer-events: none; transition: opacity 0.4s; }
  .focus-shield .gamification-bar { opacity: 0.2; pointer-events: none; transition: opacity 0.4s; }
  .focus-shield .grid { opacity: 0.15; pointer-events: none; transition: opacity 0.4s; }
  .focus-shield .adhd-dock { border: 2px solid rgba(234,179,8,0.3); border-radius: 14px; padding: 8px 16px; margin-bottom: 4px; background: rgba(234,179,8,0.03); }
  #adhd-shield-btn.active { border-color: var(--accent); color: var(--accent); background: rgba(234,179,8,0.15); }

  /* ─── RESPONSIVE ─── */
  @media (max-width: 640px) {
    .adhd-row { flex-direction: column; }
    .next-thing-widget { flex: 1; min-width: 0; }
    .three-sec-widget { flex: 1; min-width: 0; }
    .energy-widget { flex: 1; min-width: 0; }
    .microgoal-widget { flex: 1; min-width: 0; }
    .quote-widget { flex: 1; min-width: 0; }
    .streak-widget { flex: 0; }
    .mg-grid { gap: 3px; }
    .mg-btn { font-size: 10px; padding: 4px 8px; }
  }
</style>
</head>
<body>

<!-- ─── CONFETTI ─── -->
<div id="confetti-container"></div>

<!-- ─── FOCUS OVERLAY ─── -->
<div class="focus-overlay" id="focusOverlay" onclick="toggleFocusMode()"></div>

<!-- ─── BOOKMARKS PANEL ─── -->
<div class="bookmarks-panel" id="bookmarksPanel">
  <h3>📌 Saved for Later <button class="close-btn" onclick="toggleBookmarks()">✕</button></h3>
  <div id="bookmarksList"><div class="bookmarks-empty">No saved articles yet.<br>Click the 📌 on any article.</div></div>
</div>

<!-- ─── SOCIAL AMPLIFICATION PANEL ─── -->
<div class="bookmarks-panel" id="socialPanel">
  <h3>📢 Social Amplification <button class="close-btn" onclick="toggleSocial()">✕</button></h3>
  <div style="font-size:13px;color:var(--muted);margin-bottom:16px;">Share articles, create collections, and schedule posts.</div>
  <div id="socialContent">
    <div style="padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);margin-bottom:12px;">
      <h4 style="font-size:14px;margin-bottom:8px;color:var(--accent);">🚀 Ready to Go Live</h4>
      <p style="font-size:12px;line-height:1.6;color:var(--muted);">12-asset amplification kit ready at <code style="background:rgba(0,0,0,0.3);padding:2px 6px;border-radius:4px;font-size:11px;">social-outbox/earnings-go-live/</code></p>
      <div style="font-size:12px;color:var(--text);margin-top:10px;">📋 Assets: 12 posts • 🎯 Topics: UPSC, Psychology, Tech • 📱 Platforms: X, Threads, LinkedIn</div>
    </div>
    <div style="padding:16px;background:var(--surface);border:1px solid var(--border);border-radius:var(--radius-sm);">
      <h4 style="font-size:14px;margin-bottom:8px;color:var(--info);">📊 Publishing Pipeline</h4>
      <div id="socialPipeline">
        <div style="font-size:12px;color:var(--muted);">⏳ Awaiting token drop from Venkat to activate ₹10k social blast</div>
        <div style="font-size:11px;color:var(--muted);margin-top:6px;">🔗 zFinance pipeline handoff → T+0 publish</div>
      </div>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px;">
      <button class="tool-btn primary" onclick="showNotification('📢 Social pipeline ready — waiting for token drop!','accent')" style="flex:1;justify-content:center;">▶ Preview Queue</button>
      <button class="tool-btn" onclick="showNotification('📋 12 assets staged: 4 UPSC, 4 Psychology, 4 Tech','accent2')" style="flex:1;justify-content:center;">📦 Asset Kit</button>
    </div>
  </div>
</div>

<!-- ─── FEED MANAGER PANEL ─── -->
<div class="feed-panel" id="feedPanel">
  <div class="feed-panel-header">
    <h3>📡 Feed Manager <span style="font-weight:400;font-size:12px;color:var(--muted)">— manage RSS feeds &amp; search topics</span></h3>
    <button class="close-btn" onclick="toggleFeedManager()">✕</button>
  </div>
  <div class="feed-tabs">
    <button class="feed-tab active" id="tabFeedsRSS" onclick="switchFeedTab('rss')">📰 RSS Feeds</button>
    <button class="feed-tab" id="tabFeedsTopics" onclick="switchFeedTab('topics')">🔍 SearXNG Topics</button>
  </div>
  <!-- RSS Tab -->
  <div class="feed-tab-content active" id="feedRSS">
    <div class="feed-add-form">
      <input type="text" id="newRssId" placeholder="Feed id (e.g. 'nyt_home')" class="feed-input">
      <input type="url" id="newRssUrl" placeholder="Feed URL (e.g. https://...)" class="feed-input" style="flex:2">
      <button class="tool-btn primary" onclick="addRSSFeed()">+ Add Feed</button>
    </div>
    <div class="feed-list" id="rssFeedList">
      <div class="feed-loading">Loading feeds...</div>
    </div>
    <div class="feed-actions">
      <button class="tool-btn" onclick="resetFeeds()" style="color:var(--danger);border-color:rgba(248,113,113,0.3)">↺ Reset to Defaults</button>
    </div>
  </div>
  <!-- Topics Tab -->
  <div class="feed-tab-content" id="feedTopics">
    <div class="feed-add-form">
      <input type="text" id="newTopicId" placeholder="Topic id (e.g. 'tech')" class="feed-input">
      <input type="text" id="newTopicLabel" placeholder="Label (e.g. 'Technology')" class="feed-input">
      <input type="text" id="newTopicQuery" placeholder="SearXNG query" class="feed-input" style="flex:2">
      <button class="tool-btn primary" onclick="addTopic()">+ Add Topic</button>
    </div>
    <div class="feed-list" id="topicList">
      <div class="feed-loading">Loading topics...</div>
    </div>
    <div class="feed-actions">
      <button class="tool-btn" onclick="resetFeeds()" style="color:var(--danger);border-color:rgba(248,113,113,0.3)">↺ Reset to Defaults</button>
    </div>
  </div>
</div>

<!-- ─── TUTOR PANEL ─── -->
<div class="tutor-panel" id="tutorPanel">
  <h3>🧠 Tutor-OC <span class="tutor-mode-badge">CSAT • PSYCH</span><button class="close-btn" onclick="toggleTutor()">✕</button></h3>
  <div class="tutor-tabs">
    <button class="tutor-tab active" id="tabCSAT" onclick="switchTutorTab('csat')">📝 CSAT Practice</button>
    <button class="tutor-tab" id="tabPSYCH" onclick="switchTutorTab('psych')">🧠 PSYCH Refresher</button>
    <button class="tutor-tab" id="tabDaily" onclick="switchTutorTab('daily')">🎯 Daily Challenge</button>
  </div>
  <!-- CSAT Tab -->
  <div class="tutor-content active" id="tutorCSAT">
    <div class="csat-question" id="csatQuestion">Loading question…</div>
    <div class="csat-options" id="csatOptions"></div>
    <div id="csatResult"></div>
    <div class="csat-controls">
      <button class="primary" onclick="submitCSAT()" id="csatSubmitBtn">✅ Submit</button>
      <button onclick="nextCSAT()" id="csatNextBtn" style="display:none">➡ Next Question</button>
      <button onclick="newCSATSet()">🔄 New Set</button>
    </div>
    <div class="csat-stats" id="csatStats">
      <span>📊 Q: <strong id="csatNum">0</strong>/10</span>
      <span>✅ Correct: <strong id="csatCorrect">0</strong></span>
      <span>❌ Wrong: <strong id="csatWrong">0</strong></span>
      <span>⭐ XP Earned: <strong id="csatXP">0</strong></span>
    </div>
  </div>
  <!-- PSYCH Tab -->
  <div class="tutor-content" id="tutorPSYCH">
    <div class="psych-card" id="psychCard">
      <h4 id="psychConcept">Loading…</h4>
      <p id="psychText">Please wait while concepts load.</p>
      <div class="tags" id="psychTags"></div>
    </div>
    <div class="psych-nav">
      <button onclick="prevPsych()">◀ Previous</button>
      <span id="psychCounter">1/20</span>
      <button onclick="nextPsych()">Next ▶</button>
    </div>
  </div>
  <!-- Daily Challenge Tab -->
  <div class="tutor-content" id="tutorDaily">
    <div style="text-align:center;padding:10px 0;">
      <div style="font-size:13px;color:var(--muted);margin-bottom:4px;">
        📅 Day <span id="challengeDayNum">1</span> of 30
      </div>
      <div style="font-size:12px;color:var(--muted);margin-bottom:12px;">
        🔥 Streak: <span id="challengeStreak">0</span> days ⭐ XP: <span id="challengeXP">0</span>
      </div>
      <div id="challengeQuestionCard" style="background:var(--surface);border:1px solid var(--border);border-radius:12px;padding:20px;margin:8px 0;">
        <div id="challengeLead" style="font-size:13px;color:var(--accent);margin-bottom:8px;">🎯 Question of the Day</div>
        <div id="challengeQuestion" style="font-size:16px;line-height:1.6;margin-bottom:16px;"></div>
        <div id="challengeOptions"></div>
        <div id="challengeTimer" style="font-size:13px;color:var(--muted);margin-top:12px;">⏱️ <span id="challengeTimeLeft">15</span>s</div>
      </div>
      <div id="challengeResult" style="display:none;margin-top:12px;"></div>
      <button id="challengeNextBtn" style="display:none;margin-top:12px;padding:8px 20px;background:var(--accent);border:none;border-radius:8px;color:#fff;cursor:pointer;font-size:13px;">Next Day →</button>
    </div>
  </div>
</div>

<!-- ─── TTS TOAST ─── -->
<div class="tts-toast" id="ttsToast">
  <span class="info" id="ttsInfo">🔊 Speaking...</span>
  <button onclick="stopTTS()" class="stop">⏹ Stop</button>
  <button onclick="pauseTTS()" id="ttsPauseBtn">⏸ Pause</button>
</div>

<!-- ─── HEADER ─── -->
<header>
  <div class="bar">
    <div class="brand">
      <span class="brand-logo">⚡</span>
      <span>Pulse</span>
      <span class="brand-sub">news • 2hr window</span>
    </div>
    <div class="pills" id="topicPills"></div>
    <div class="header-actions">
      <div class="search-box">
        <span style="color:var(--muted);font-size:13px;">🔍</span>
        <input type="text" id="searchInput" placeholder="Filter articles..." oninput="onSearch()">
      </div>
      <button id="rescanBtn" class="tool-btn primary" onclick="triggerRescan()">↻ Rescan</button>
    </div>
  </div>
</header>

<!-- ─── TOOLBAR ─── -->
<div class="toolbar">
  <div class="toolbar-left">
    <button class="tool-btn" id="focusBtn" onclick="toggleFocusMode()" title="Focus Mode — strip to essentials">🎯 Focus</button>
    <button class="tool-btn" id="upscBtn" onclick="toggleUPSCLens()" title="UPSC Lens — surface syllabus-relevant news">📚 UPSC</button>
    <button class="tool-btn" id="energyBtn" onclick="toggleEnergyMode()" title="Energy Mode — low-spoon reading">🔋 Energy</button>
    <button class="tool-btn" id="bookmarkBtn" onclick="toggleBookmarks()" title="Saved articles">📌 Saved</button>
    <button class="tool-btn" id="feedBtn" onclick="toggleFeedManager()" title="Manage RSS feeds and SearXNG queries">📡 Feeds</button>
    <button class="tool-btn" id="csatBtn" onclick="toggleTutor('csat')" title="CSAT Practice — daily quiz" style="background:rgba(96,165,250,0.12);border-color:rgba(96,165,250,0.3)">📝 CSAT</button>
    <button class="tool-btn" id="psychBtn" onclick="toggleTutor('psych')" title="Psychology Quick Reference — revision cards" style="background:rgba(34,197,94,0.12);border-color:rgba(34,197,94,0.3)">🧠 PSYCH</button>
    <div class="pomodoro-wrap">
      <button class="tool-btn" id="pomodoroBtn" onclick="togglePomodoro()" title="Pomodoro Timer">⏱ Timer</button>
      <button class="tool-btn" id="socialBtn" onclick="toggleSocial()" title="Social Amplification — share, threads, collections" style="background:rgba(167,139,250,0.12);border-color:rgba(167,139,250,0.3)">📢 Social</button>
      <div class="pomodoro-panel" id="pomodoroPanel">
        <div class="pomodoro-label" id="pomodoroLabel">Focus</div>
        <div class="pomodoro-display" id="pomodoroDisplay">25:00</div>
        <div class="pomodoro-controls">
          <button onclick="startPomodoro()" id="pomStartBtn">▶ Start</button>
          <button onclick="resetPomodoro()">↺ Reset</button>
          <button onclick="cyclePomodoroMode()" title="Toggle focus/break">🔄</button>
        </div>
      </div>
    </div>
  </div>
  <div class="toolbar-right">
    <span class="status-line" id="statusLine">Loading…</span>
    <span id="clockLine"></span>
  </div>
</div>

<!-- ─── GAMIFICATION BAR ─── -->
<div class="gamification-bar" id="gamificationBar">
  <span class="stat-badge" id="streakBadge">🔥 Streak: <span class="num" id="streakCount">0</span>d</span>
  <span class="stat-badge" id="xpBadge">⭐ XP: <span class="num" id="xpCount">0</span></span>
  <div class="xp-bar-wrap"><div class="xp-bar-fill" id="xpBarFill"></div></div>
  <span class="stat-badge" id="articlesReadBadge">📖 Read: <span class="num" id="articlesReadCount">0</span></span>
  <div class="daily-goal">
    <span>Daily Goal</span>
    <div class="progress"><div class="fill" id="dailyGoalFill" style="width:0%"></div></div>
    <span id="dailyGoalText">0/5</span>
  </div>
</div>

<!-- ─── BREAKING NEWS ─── -->
<div class="breaking" id="breakingArea"></div>

<!-- ─── MAIN CONTENT ─── -->
<main>
  <div class="grid" id="grid"></div>
</main>

<script src="app.js"></script>
<script src="adhd-features.js"></script>

</body>
</html>
