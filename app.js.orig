// ─── TOPICS ───
const TOPICS = [
  {id:'india',label:'🇮🇳 India'},
  {id:'tamilnadu',label:'📍 Tamil Nadu'},
  {id:'andhra',label:'📍 Andhra Pradesh'},
  {id:'world',label:'🌍 International'},
  {id:'finance',label:'💰 Finance & Economy'},
  {id:'earnings',label:'💼 Earning Opportunities'},
  {id:'sports',label:'🏏 Sports'},
  {id:'national_sports',label:'🏏 National Sports'},
  {id:'international_sports',label:'⚽ Intl. Sports'},
];
let active = new Set(TOPICS.map(t => t.id));
let query = "";
let allArticles = [];
let isFocus = false;
let isUPSC = false;
let isEnergy = false;

// ─── UTILITY ───
function fmtTime(iso) {
  if (!iso) return "";
  const d = new Date(iso);
  return d.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit'});
}
function escapeHtml(s) {
  return String(s || '').replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function matchesQuery(article) {
  if (!query) return true;
  const q = query.toLowerCase();
  return ((article.title || '') + ' ' + (article.snippet || '')).toLowerCase().includes(q);
}

// ─── CLOCK ───
function updateClock() {
  const el = document.getElementById('clockLine');
  if (!el) return;
  const now = new Date();
  el.textContent = '🕒 ' + now.toLocaleTimeString([], {hour:'2-digit', minute:'2-digit', second:'2-digit', hour12:true, timeZone:'Asia/Kolkata'}) + ' IST';
}
setInterval(updateClock, 1000);
updateClock();

// ─── SEARCH ───
function onSearch() {
  query = document.getElementById('searchInput').value;
  refresh();
}
let searchTimer = null;
document.addEventListener('keydown', e => {
  if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
    e.preventDefault();
    document.getElementById('searchInput').focus();
  }
});

// ─── GAMIFICATION ───
function getGamification() {
  try {
    const raw = localStorage.getItem('pulse_gamification');
    return raw ? JSON.parse(raw) : {streak:0, xp:0, articlesRead:0, lastDate:null, dailyCount:0, dailyGoal:5, level:1};
  } catch { return {streak:0, xp:0, articlesRead:0, lastDate:null, dailyCount:0, dailyGoal:5, level:1}; }
}
function saveGamification(g) {
  localStorage.setItem('pulse_gamification', JSON.stringify(g));
}
function updateGamificationUI() {
  const g = getGamification();
  const today = new Date().toISOString().slice(0,10);
  // Reset daily if new day
  if (g.lastDate !== today) {
    g.dailyCount = 0;
    g.lastDate = today;
    // Check streak
    if (g.lastDate) {
      const prev = new Date(g.lastDate);
      const now = new Date(today);
      const diff = (now - prev) / 86400000;
      if (diff > 1.5) g.streak = 0;
    }
    saveGamification(g);
  }
  document.getElementById('streakCount').textContent = g.streak;
  document.getElementById('xpCount').textContent = g.xp;
  document.getElementById('articlesReadCount').textContent = g.articlesRead;
  // XP bar (next level at 100 XP)
  const xpInLevel = g.xp % 100;
  document.getElementById('xpBarFill').style.width = Math.min(xpInLevel, 100) + '%';
  // Daily goal
  const pct = Math.min((g.dailyCount / g.dailyGoal) * 100, 100);
  document.getElementById('dailyGoalFill').style.width = pct + '%';
  document.getElementById('dailyGoalText').textContent = `${g.dailyCount}/${g.dailyGoal}`;
  // Streak highlight
  const sb = document.getElementById('streakBadge');
  sb.classList.toggle('highlight', g.streak >= 3);
}
function awardXP(amount) {
  const g = getGamification();
  const oldLevel = Math.floor(g.xp / 100);
  g.xp += amount;
  const newLevel = Math.floor(g.xp / 100);
  g.articlesRead += 1;
  g.dailyCount = (g.dailyCount || 0) + 1;
  g.lastDate = new Date().toISOString().slice(0,10);
  // Streak
  if (!g.streakDate) {
    g.streak = 1;
    g.streakDate = g.lastDate;
  } else if (g.streakDate !== g.lastDate) {
    const prev = new Date(g.streakDate);
    const now = new Date(g.lastDate);
    const diff = (now - prev) / 86400000;
    if (diff <= 1.5) {
      g.streak += 1;
    } else {
      g.streak = 1;
    }
    g.streakDate = g.lastDate;
  }
  saveGamification(g);
  updateGamificationUI();
  if (newLevel > oldLevel) {
    triggerConfetti();
    showNotification(`🎉 Level ${newLevel}! You're on fire! 🔥`, 'accent');
  }
}
function markArticleRead(title) {
  awardXP(5);
}

// ─── CONFETTI ───
function triggerConfetti() {
  const container = document.getElementById('confetti-container');
  const colors = ['#eab308','#22c55e','#f87171','#60a5fa','#a78bfa','#fb923c','#34d399','#f472b6'];
  for (let i = 0; i < 40; i++) {
    const piece = document.createElement('div');
    piece.className = 'confetti-piece';
    const color = colors[Math.floor(Math.random() * colors.length)];
    const size = 6 + Math.random() * 8;
    piece.style.cssText = `
      left: ${Math.random() * 100}%;
      top: -10%;
      width: ${size}px; height: ${size * (0.5 + Math.random())}px;
      background: ${color};
      border-radius: ${Math.random() > 0.5 ? '50%' : '2px'};
      animation-delay: ${Math.random() * 0.5}s;
      animation-duration: ${2 + Math.random() * 2}s;
      transform: rotate(${Math.random() * 360}deg);
    `;
    container.appendChild(piece);
    setTimeout(() => piece.remove(), 4000);
  }
}

// ─── NOTIFICATIONS ───
function showNotification(msg, type) {
  const el = document.createElement('div');
  el.style.cssText = `
    position: fixed; top: 20px; right: 20px; z-index: 9999;
    background: var(--panel); border: 1px solid var(--${type || 'accent'});
    border-radius: 12px; padding: 12px 20px; color: var(--text);
    font-size: 14px; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    animation: fadeSlideUp 0.3s ease; max-width: 300px;
  `;
  el.textContent = msg;
  document.body.appendChild(el);
  setTimeout(() => {
    el.style.opacity = '0';
    el.style.transition = 'opacity 0.3s';
    setTimeout(() => el.remove(), 300);
  }, 3000);
}

// ─── FOCUS MODE ───
function toggleFocusMode() {
  isFocus = !isFocus;
  document.body.classList.toggle('focus-mode', isFocus);
  document.getElementById('focusBtn').classList.toggle('active', isFocus);
  document.getElementById('focusOverlay').classList.toggle('active', isFocus);
  localStorage.setItem('pulse_focus', isFocus);
}
function toggleFocusOverlay() { if (isFocus) toggleFocusMode(); }

// ─── UPSC LENS ───
function toggleUPSCLens() {
  isUPSC = !isUPSC;
  document.body.classList.toggle('upsc-lens', isUPSC);
  document.getElementById('upscBtn').classList.toggle('active', isUPSC);
  localStorage.setItem('pulse_upsc', isUPSC);
}

// ─── ENERGY MODE ───
function toggleEnergyMode() {
  isEnergy = !isEnergy;
  document.body.classList.toggle('energy-low', isEnergy);
  document.getElementById('energyBtn').classList.toggle('active', isEnergy);
  localStorage.setItem('pulse_energy', isEnergy);
}

// ─── BOOKMARKS ───
function getBookmarks() {
  try { return JSON.parse(localStorage.getItem('pulse_bookmarks') || '[]'); } catch { return []; }
}
function saveBookmarks(b) { localStorage.setItem('pulse_bookmarks', JSON.stringify(b)); }
function toggleBookmarks() {
  const panel = document.getElementById('bookmarksPanel');
  panel.classList.toggle('open');
  document.getElementById('socialPanel').classList.remove('open');
  renderBookmarks();
}
function toggleSocial() {
  const panel = document.getElementById('socialPanel');
  panel.classList.toggle('open');
  document.getElementById('bookmarksPanel').classList.remove('open');
}
function renderBookmarks() {
  const list = document.getElementById('bookmarksList');
  const bks = getBookmarks();
  if (!bks.length) {
    list.innerHTML = '<div class="bookmarks-empty">No saved articles yet.<br>Click the 📌 on any article.</div>';
    return;
  }
  list.innerHTML = bks.map((b, i) => `
    <div class="bookmark-item">
      <button class="bookmark-remove" onclick="removeBookmark(${i})">✕</button>
      <a href="${escapeHtml(b.url)}" target="_blank" rel="noopener">${escapeHtml(b.title)}</a>
      <div class="bookmark-meta">${escapeHtml(b.source || '')} • ${fmtTime(b.published)}</div>
    </div>
  `).join('');
}
function toggleBookmark(article) {
  const bks = getBookmarks();
  const idx = bks.findIndex(b => b.url === article.url);
  if (idx >= 0) {
    bks.splice(idx, 1);
    saveBookmarks(bks);
    refresh();
    return false; // removed
  } else {
    bks.unshift({title: article.title, url: article.url, source: article.source, published: article.published});
    saveBookmarks(bks);
    showNotification('📌 Saved!', 'accent2');
    return true; // added
  }
}
function removeBookmark(idx) {
  const bks = getBookmarks();
  bks.splice(idx, 1);
  saveBookmarks(bks);
  renderBookmarks();
}
function isBookmarked(url) {
  return getBookmarks().some(b => b.url === url);
}

// ─── FEED MANAGER ───
let feedsData = { rss_feeds: [], topics: [] };

function toggleFeedManager() {
  const panel = document.getElementById('feedPanel');
  panel.classList.toggle('open');
  if (panel.classList.contains('open')) {
    loadFeeds();
  }
}

function loadFeeds() {
  fetch('/feeds.json?t=' + Date.now())
    .then(r => r.json())
    .then(data => {
      feedsData = data;
      renderRSSFeeds(data.rss_feeds || []);
      renderTopics(data.topics || []);
    })
    .catch(() => {
      document.getElementById('rssFeedList').innerHTML = '<div class="feed-error">❌ Failed to load feeds</div>';
      document.getElementById('topicList').innerHTML = '<div class="feed-error">❌ Failed to load topics</div>';
    });
}

function renderRSSFeeds(feeds) {
  const list = document.getElementById('rssFeedList');
  if (!feeds.length) {
    list.innerHTML = '<div class="feed-loading">No RSS feeds configured.</div>';
    return;
  }
  list.innerHTML = feeds.map(f => {
    const isDefault = f.id && ['pib','thehindu_national','indianexpress_india','indianexpress_politics','indianexpress_business','indianexpress_world','indianexpress_explained','thehindu_tn','thehindu_ap','reuters_world','thehindu_sports','indianexpress_sports','reuters_sports','espn_world','bbc_sport','sportskeeda','cricbuzz'].includes(f.id);
    return `<div class="feed-item${f.enabled === false ? ' disabled' : ''}">
      <button class="feed-toggle${f.enabled !== false ? ' on' : ''}" onclick="toggleRSSFeed('${f.id}', ${f.enabled !== false ? 'false' : 'true'})"></button>
      <span class="feed-item-id">${escapeHtml(f.id)}</span>
      <span class="feed-item-url" title="${escapeHtml(f.url)}">${escapeHtml(f.url)}</span>
      <button class="feed-remove-btn" onclick="removeRSSFeed('${f.id}')" title="${isDefault ? 'Default — will restore on reset' : 'Remove feed'}">${isDefault ? '🔒' : '✕'}</button>
    </div>`;
  }).join('');
}

function renderTopics(topics) {
  const list = document.getElementById('topicList');
  if (!topics.length) {
    list.innerHTML = '<div class="feed-loading">No search topics configured.</div>';
    return;
  }
  list.innerHTML = topics.map(t => {
    const isDefault = t.id && ['india','tamilnadu','andhra','world','sports','national_sports','international_sports'].includes(t.id);
    return `<div class="feed-item${t.enabled === false ? ' disabled' : ''}">
      <button class="feed-toggle${t.enabled !== false ? ' on' : ''}" onclick="toggleTopic('${t.id}', ${t.enabled !== false ? 'false' : 'true'})"></button>
      <span class="feed-item-label">${escapeHtml(t.label || t.id)}</span>
      <span class="feed-item-query">🔍 ${escapeHtml(t.query)}</span>
      <button class="feed-remove-btn" onclick="removeTopic('${t.id}')" title="${isDefault ? 'Default — will restore on reset' : 'Remove topic'}">${isDefault ? '🔒' : '✕'}</button>
    </div>`;
  }).join('');
}

function switchFeedTab(tab) {
  document.querySelectorAll('.feed-tab').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.feed-tab-content').forEach(el => el.classList.remove('active'));
  if (tab === 'rss') {
    document.getElementById('tabFeedsRSS').classList.add('active');
    document.getElementById('feedRSS').classList.add('active');
  } else {
    document.getElementById('tabFeedsTopics').classList.add('active');
    document.getElementById('feedTopics').classList.add('active');
  }
}

function addRSSFeed() {
  const id = document.getElementById('newRssId').value.trim();
  const url = document.getElementById('newRssUrl').value.trim();
  if (!id || !url) { showNotification('⚠️ Fill in both feed id and URL', 'info'); return; }
  if (!id.match(/^[a-z0-9_]+$/)) { showNotification('⚠️ Feed id: lowercase letters, numbers, underscores only', 'info'); return; }
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'add_rss', id: id, url: url})
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      document.getElementById('newRssId').value = '';
      document.getElementById('newRssUrl').value = '';
      renderRSSFeeds(data.rss_feeds || []);
      showNotification('✅ Feed added: ' + id, 'accent2');
    } else if (data.error) {
      showNotification('❌ ' + data.error, 'danger');
    }
  }).catch(() => showNotification('❌ Failed to add feed', 'danger'));
}

function removeRSSFeed(id) {
  const isDefault = ['pib','thehindu_national','indianexpress_india','indianexpress_politics','indianexpress_business','indianexpress_world','indianexpress_explained','thehindu_tn','thehindu_ap','reuters_world','thehindu_sports','indianexpress_sports','reuters_sports','espn_world','bbc_sport','sportskeeda','cricbuzz'].includes(id);
  if (isDefault) { showNotification('🔒 Default feed — use Reset to restore', 'info'); return; }
  if (!confirm('Remove feed "' + id + '"?')) return;
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'remove_rss', id: id})
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      renderRSSFeeds(data.rss_feeds || []);
      showNotification('🗑️ Feed removed: ' + id, 'info');
    } else if (data.error) {
      showNotification('❌ ' + data.error, 'danger');
    }
  }).catch(() => showNotification('❌ Failed to remove feed', 'danger'));
}

function toggleRSSFeed(id, enabled) {
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'toggle_rss', id: id, enabled: enabled})
  }).then(r => r.json()).then(data => {
    if (data.ok) renderRSSFeeds(data.rss_feeds || []);
  });
}

function addTopic() {
  const id = document.getElementById('newTopicId').value.trim();
  const label = document.getElementById('newTopicLabel').value.trim() || id;
  const query = document.getElementById('newTopicQuery').value.trim();
  if (!id || !query) { showNotification('⚠️ Fill in topic id and query', 'info'); return; }
  if (!id.match(/^[a-z0-9_]+$/)) { showNotification('⚠️ Topic id: lowercase letters, numbers, underscores only', 'info'); return; }
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'add_topic', id: id, label: label, query: query})
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      document.getElementById('newTopicId').value = '';
      document.getElementById('newTopicLabel').value = '';
      document.getElementById('newTopicQuery').value = '';
      renderTopics(data.topics || []);
      showNotification('✅ Topic added: ' + label, 'accent2');
    } else if (data.error) {
      showNotification('❌ ' + data.error, 'danger');
    }
  }).catch(() => showNotification('❌ Failed to add topic', 'danger'));
}

function removeTopic(id) {
  const isDefault = ['india','tamilnadu','andhra','world','sports','national_sports','international_sports'].includes(id);
  if (isDefault) { showNotification('🔒 Default topic — use Reset to restore', 'info'); return; }
  if (!confirm('Remove topic "' + id + '"?')) return;
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'remove_topic', id: id})
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      renderTopics(data.topics || []);
      showNotification('🗑️ Topic removed: ' + id, 'info');
    } else if (data.error) {
      showNotification('❌ ' + data.error, 'danger');
    }
  }).catch(() => showNotification('❌ Failed to remove topic', 'danger'));
}

function toggleTopic(id, enabled) {
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'toggle_topic', id: id, enabled: enabled})
  }).then(r => r.json()).then(data => {
    if (data.ok) renderTopics(data.topics || []);
  });
}

function resetFeeds() {
  if (!confirm('Reset all feeds and topics to defaults? This will remove custom additions.')) return;
  fetch('/feeds.json', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({action: 'reset'})
  }).then(r => r.json()).then(data => {
    if (data.ok) {
      feedsData = data;
      renderRSSFeeds(data.rss_feeds || []);
      renderTopics(data.topics || []);
      showNotification('↺ Reset to defaults', 'accent');
    } else if (data.error) {
      showNotification('❌ ' + data.error, 'danger');
    }
  }).catch(() => showNotification('❌ Failed to reset', 'danger'));
}

// ─── TTS (Text-to-Speech) ───
let ttsUtterance = null;
function speakArticle(title, snippet) {
  if (window.speechSynthesis.speaking) window.speechSynthesis.cancel();
  const text = title + '. ' + (snippet || '');
  ttsUtterance = new SpeechSynthesisUtterance(text);
  ttsUtterance.rate = 0.95;
  ttsUtterance.pitch = 1.0;
  ttsUtterance.volume = 1.0;
  // Prefer Indian English voice
  const voices = window.speechSynthesis.getVoices();
  const indianVoice = voices.find(v => v.lang.startsWith('en') && (v.name.includes('India') || v.name.includes('Google UK')));
  if (indianVoice) ttsUtterance.voice = indianVoice;
  const toast = document.getElementById('ttsToast');
  const info = document.getElementById('ttsInfo');
  info.textContent = '🔊 ' + title.slice(0, 60) + (title.length > 60 ? '…' : '');
  toast.classList.add('open');
  document.getElementById('ttsPauseBtn').textContent = '⏸ Pause';
  ttsUtterance.onend = () => { toast.classList.remove('open'); };
  window.speechSynthesis.speak(ttsUtterance);
  awardXP(3);
}
function stopTTS() {
  if (window.speechSynthesis.speaking) window.speechSynthesis.cancel();
  document.getElementById('ttsToast').classList.remove('open');
}
function pauseTTS() {
  if (window.speechSynthesis.speaking) {
    if (window.speechSynthesis.paused) {
      window.speechSynthesis.resume();
      document.getElementById('ttsPauseBtn').textContent = '⏸ Pause';
    } else {
      window.speechSynthesis.pause();
      document.getElementById('ttsPauseBtn').textContent = '▶ Resume';
    }
  }
}
// Load voices early
window.speechSynthesis.getVoices();

// ─── BREAKING NEWS ───
let breakingData = [];
function renderBreaking(breaking) {
  const area = document.getElementById('breakingArea');
  if (!area) return;
  breakingData = (breaking || []).slice(0, 8);
  if (!breakingData.length) { area.innerHTML = ''; return; }
  const sources = [...new Set(breakingData.map(i => (i.source || '').trim()).filter(Boolean))];
  const top = breakingData.slice(0, 4);
  const remaining = breakingData.slice(4);
  const sourceChips = sources.map(s => '<span class="source-chip">' + escapeHtml(s) + '</span>').join('');
  const leadingBlocks = top.map((item, idx) => {
    const rank = idx + 1;
    const colorInfo = rank <= 1 ? { cls: 'break-tile--hot', badge: 'rank-hot' }
                  : rank <= 2 ? { cls: 'break-tile--warn', badge: 'rank-warn' }
                  : { cls: 'break-tile--info', badge: 'rank-info' };
    const bm = isBookmarked(item.url);
    return `<div class="break-tile ${colorInfo.cls}">
      <div class="break-rank">
        <span class="rank-badge ${colorInfo.badge}">${rank}</span>
        <a class="break-title" href="${escapeHtml(item.url)}" target="_blank" rel="noopener">${escapeHtml(item.title)}</a>
      </div>
      <div class="meta">${escapeHtml((item.source || '') + ' • ' + fmtTime(item.published))}</div>
      ${item.snippet ? `<div class="break-snippet">${escapeHtml(item.snippet)}</div>` : ''}
      <div class="item-actions">
        <button class="item-action ${bm ? 'saved' : ''}" onclick="event.stopPropagation(); toggleBookmark(${JSON.stringify(item).replace(/"/g,'&quot;')}); event.target.classList.toggle('saved'); event.target.textContent = event.target.classList.contains('saved') ? '📌 Saved' : '📌 Save'">${bm ? '📌 Saved' : '📌 Save'}</button>
        <button class="item-action" onclick="event.stopPropagation(); speakArticle(${JSON.stringify(item.title).replace(/"/g,'&quot;')}, ${JSON.stringify(item.snippet||'').replace(/"/g,'&quot;')})">🔊 Listen</button>
      </div>
    </div>`;
  }).join('');
  const railHtml = remaining.length ? `<div class="break-rail">
    <div class="break-rail-title">More Breaking</div>
    ${remaining.map(item => {
      const bm2 = isBookmarked(item.url);
      return `<div class="break-rail-item">
        <span class="break-rail-pulse"></span>
        <a class="break-rail-text" href="${escapeHtml(item.url)}" target="_blank" rel="noopener">${escapeHtml(item.title)}</a>
        <span class="break-rail-meta">
          ${escapeHtml((item.source || '') + ' • ' + fmtTime(item.published))}
          <button class="item-action ${bm2 ? 'saved' : ''}" style="font-size:10px;padding:2px 6px;margin-left:6px;" onclick="event.stopPropagation(); toggleBookmark(${JSON.stringify(item).replace(/"/g,'&quot;')}); this.classList.toggle('saved'); this.textContent = this.classList.contains('saved') ? '📌' : '📌'">${bm2 ? '📌' : '📌'}</button>
        </span>
      </div>`;
    }).join('')}
  </div>` : '';
  area.innerHTML = `<div class="breaking-board">
    <div class="breaking-header">
      <div class="breaking-brand"><span class="breaking-live">LIVE</span> Breaking</div>
      <div class="breaking-pills">${sourceChips}</div>
    </div>
    <div class="breaking-body">
      <div class="breaking-lead">${leadingBlocks}</div>
      ${railHtml}
    </div>
  </div>`;
}

// ─── MAIN RENDER ───
function render(data) {
  const grid = document.getElementById('grid');
  if (!grid) return;
  const statusLine = document.getElementById('statusLine');
  if (!data || !data.articles || !Array.isArray(data.articles)) {
    grid.innerHTML = '<div class="card"><div class="topic-header"><div class="topic-title">⚠️ Connection Issue</div></div><div class="news"><div class="empty">No data received from server. The backend may be restarting. <br><button onclick="refresh()" style="margin-top:12px;padding:8px 20px;border:1px solid var(--accent);background:transparent;color:var(--accent);border-radius:8px;cursor:pointer">↻ Retry</button></div></div></div>';
    if (statusLine) statusLine.textContent = '⚠️ Connection error';
    return;
  }
  const counts = {};
  const groups = {};
  TOPICS.forEach(t => { groups[t.id] = []; counts[t.id] = 0; });
  allArticles = data.articles.filter(matchesQuery);
  allArticles.forEach(a => {
    const id = a.topic || 'india';
    if (!groups[id]) groups[id] = [];
    counts[id] += 1;
    groups[id].push(a);
  });
  let html = '';
  TOPICS.forEach(t => {
    if (!active.has(t.id)) return;
    const items = (groups[t.id] || []).slice(0, 40);
    // UPSC score for sorting
    const upscTerms = ['ancient','medieval','modern','independence','geography','polity','governance','election','judiciary','constitution','parliament','bill','amendment','economy','budget','finance','gdp','inflation','science','technology','space','defence','cyber','biotech','energy','ethics','integrity','psychology','cognition','perception','learning','memory','society','social justice','caste','gender','education','health','climate','environment','ecology','international','summit','treaty','bilateral','security','border'];
    const sorted = [...items].sort((a, b) => {
      const aScore = upscTerms.filter(t => ((a.title||'') + ' ' + (a.snippet||'')).toLowerCase().includes(t)).length;
      const bScore = upscTerms.filter(t => ((b.title||'') + ' ' + (b.snippet||'')).toLowerCase().includes(t)).length;
      return (bScore - aScore) || (new Date(b.published||0) - new Date(a.published||0));
    });
    html += '<div class="card">' +
      '<div class="topic-header"><div class="topic-title">' + escapeHtml(t.label) + '</div><div class="topic-count">' + counts[t.id] + ' articles</div></div>' +
      '<div class="news">' + (sorted.length === 0 ? '<div class="empty">No recent coverage yet.</div>' : sorted.map(a => {
        const bm = isBookmarked(a.url);
        return '<div class="item">' +
          '<a href="' + escapeHtml(a.url) + '" target="_blank" rel="noopener" onclick="markArticleRead(' + JSON.stringify(a.title) + ')">' + escapeHtml(a.title) + '</a>' +
          '<div class="meta">' + escapeHtml(a.source || '') + ' <span class="meta-sep">•</span> ' + fmtTime(a.published) +
          '</div>' +
          (a.snippet ? '<div class="snippet">' + escapeHtml(a.snippet) + '</div>' : '') +
          '<div class="item-actions">' +
            '<button class="item-action ' + (bm ? 'saved' : '') + '" onclick="toggleBookmark(' + JSON.stringify(a).replace(/"/g,'&quot;') + '); this.classList.toggle(\'saved\'); this.textContent = this.classList.contains(\'saved\') ? \'📌 Saved\' : \'📌 Save\'">' + (bm ? '📌 Saved' : '📌 Save') + '</button>' +
            '<button class="item-action" onclick="speakArticle(' + JSON.stringify(a.title).replace(/"/g,'&quot;') + ', ' + JSON.stringify(a.snippet||'').replace(/"/g,'&quot;') + ')">🔊 Listen</button>' +
          '</div>' +
        '</div>';
      }).join('')) + '</div></div>';
  });
  grid.innerHTML = html;
  document.getElementById('statusLine').textContent = allArticles.length + ' articles in 2hr window';
  renderBreaking((data.breaking && data.breaking.length) ? data.breaking : allArticles.slice(0, 8));
}

// ─── REFRESH ───
function refresh() {
  const statusLine = document.getElementById('statusLine');
  if (statusLine) statusLine.textContent = '⟳ Loading…';
  fetch('/status.json?t=' + Date.now()).then(r => {
    if (!r.ok) throw new Error('HTTP ' + r.status);
    return r.json();
  }).then(render).catch(() => {
    const grid = document.getElementById('grid');
    if (grid && !grid.children.length) {
      grid.innerHTML = '<div class="card"><div class="topic-header"><div class="topic-title">🔌 Offline</div></div><div class="news"><div class="empty">Could not reach server. Retrying automatically…</div></div></div>';
    }
    if (statusLine) statusLine.textContent = '⚠️ Retrying…';
    // auto-retry in 10s on failure
    setTimeout(refresh, 10000);
  });
}
function triggerRescan() {
  document.getElementById('rescanBtn').textContent = '↻ Scanning…';
  fetch('/rescan', {method:'POST'}).then(() => {
    setTimeout(refresh, 2000);
    setTimeout(() => document.getElementById('rescanBtn').textContent = '↻ Rescan', 3000);
  });
}

// ─── POMODORO ───
let pomodoroMinutes = 25;
let pomodoroSeconds = 0;
let pomodoroRunning = false;
let pomodoroInterval = null;
let pomodoroMode = 'focus'; // focus | break
function togglePomodoro() {
  document.getElementById('pomodoroPanel').classList.toggle('open');
}
function updatePomodoroDisplay() {
  const m = String(pomodoroMinutes).padStart(2, '0');
  const s = String(pomodoroSeconds).padStart(2, '0');
  document.getElementById('pomodoroDisplay').textContent = m + ':' + s;
}
function startPomodoro() {
  if (pomodoroRunning) {
    clearInterval(pomodoroInterval);
    pomodoroRunning = false;
    document.getElementById('pomStartBtn').textContent = '▶ Start';
    return;
  }
  if (pomodoroMinutes === 0 && pomodoroSeconds === 0) resetPomodoro();
  pomodoroRunning = true;
  document.getElementById('pomStartBtn').textContent = '⏸ Pause';
  pomodoroInterval = setInterval(() => {
    if (pomodoroSeconds === 0) {
      if (pomodoroMinutes === 0) {
        clearInterval(pomodoroInterval);
        pomodoroRunning = false;
        document.getElementById('pomStartBtn').textContent = '▶ Start';
        // Timer finished
        if (pomodoroMode === 'focus') {
          triggerConfetti();
          showNotification('🎯 Focus session complete! Take a break!', 'accent2');
          // Auto-switch to break
          pomodoroMode = 'break';
          pomodoroMinutes = 5;
          pomodoroSeconds = 0;
          document.getElementById('pomodoroLabel').textContent = '☕ Break';
          awardXP(20);
        } else {
          showNotification('☕ Break over! Ready to focus?', 'accent');
          pomodoroMode = 'focus';
          pomodoroMinutes = 25;
          pomodoroSeconds = 0;
          document.getElementById('pomodoroLabel').textContent = '🎯 Focus';
        }
        updatePomodoroDisplay();
        return;
      }
      pomodoroMinutes--;
      pomodoroSeconds = 59;
    } else {
      pomodoroSeconds--;
    }
    updatePomodoroDisplay();
  }, 1000);
}
function resetPomodoro() {
  clearInterval(pomodoroInterval);
  pomodoroRunning = false;
  document.getElementById('pomStartBtn').textContent = '▶ Start';
  if (pomodoroMode === 'focus') { pomodoroMinutes = 25; document.getElementById('pomodoroLabel').textContent = '🎯 Focus'; }
  else { pomodoroMinutes = 5; document.getElementById('pomodoroLabel').textContent = '☕ Break'; }
  pomodoroSeconds = 0;
  updatePomodoroDisplay();
}
function cyclePomodoroMode() {
  if (pomodoroMode === 'focus') {
    pomodoroMode = 'break';
    pomodoroMinutes = 5;
    document.getElementById('pomodoroLabel').textContent = '☕ Break';
  } else {
    pomodoroMode = 'focus';
    pomodoroMinutes = 25;
    document.getElementById('pomodoroLabel').textContent = '🎯 Focus';
  }
  pomodoroSeconds = 0;
  resetPomodoro();
}

// ─── PILLS ───
function renderPills() {
  document.getElementById('topicPills').innerHTML = TOPICS.map(t => {
    const on = active.has(t.id);
    return '<button class="pill' + (on ? ' active' : '') + '" data-id="' + t.id + '">' + (on ? '✓ ' : '') + t.label + '</button>';
  }).join('');
  document.getElementById('topicPills').addEventListener('click', e => {
    const btn = e.target.closest('.pill');
    if (!btn) return;
    const id = btn.dataset.id;
    if (active.has(id)) active.delete(id); else active.add(id);
    renderPills();
    refresh();
  });
}

// ─── RESTORE PREFERENCES ───
function restorePreferences() {
  try {
    if (localStorage.getItem('pulse_focus') === 'true') toggleFocusMode();
    if (localStorage.getItem('pulse_upsc') === 'true') toggleUPSCLens();
    if (localStorage.getItem('pulse_energy') === 'true') toggleEnergyMode();
  } catch(e) {}
}

// ─── INIT ───
renderPills();
refresh();
updateGamificationUI();
restorePreferences();
setInterval(refresh, 300000); // auto-refresh every 5min
setInterval(updateGamificationUI, 60000); // update gamification

// ═══════════════════════════════════════════
// TUTOR-OC: CSAT Practice + Psychology Refresher
// ═══════════════════════════════════════════

// ─── CSAT Question Bank ───
const CSAT_BANK = [
  {
    q: 'If 60% of students in a class are boys and the number of girls is 24, what is the total number of students?',
    opts: ['48', '60', '72', '80'],
    ans: 1,
    exp: 'Girls = 40% = 24. Total = 24/40 × 100 = 60.'
  },
  {
    q: 'A train 150m long passes a pole in 15 seconds. What is its speed in km/h?',
    opts: ['36 km/h', '42 km/h', '48 km/h', '54 km/h'],
    ans: 0,
    exp: 'Speed = Distance/Time = 150/15 = 10 m/s = 10 × 18/5 = 36 km/h.'
  },
  {
    q: 'If A : B = 2 : 3 and B : C = 4 : 5, then A : C = ?',
    opts: ['8 : 15', '5 : 8', '2 : 5', '3 : 5'],
    ans: 0,
    exp: 'A/B = 2/3, B/C = 4/5. A/C = (2/3)×(4/5) = 8/15, so A:C = 8:15.'
  },
  {
    q: 'What is the next number in the series: 2, 6, 12, 20, 30, ?',
    opts: ['38', '40', '42', '44'],
    ans: 2,
    exp: 'Pattern: 1×2=2, 2×3=6, 3×4=12, 4×5=20, 5×6=30, so next = 6×7 = 42.'
  },
  {
    q: 'A is the father of B. B is the sister of C. D is the mother of C. How is D related to A?',
    opts: ['Sister', 'Wife', 'Daughter', 'Mother'],
    ans: 1,
    exp: 'A is father of B and C, D is mother of C. So D is A\'s wife.'
  },
  {
    q: 'All roses are flowers. Some flowers fade quickly. Therefore:',
    opts: ['Some roses fade quickly', 'All flowers fade quickly', 'None of these', 'All roses are flowers that fade quickly'],
    ans: 2,
    exp: 'We cannot conclude that some roses fade quickly — the "some" may be other flowers. So "None of these" is correct.'
  },
  {
    q: 'The average weight of 5 people is 60 kg. If one person leaves, the average drops to 58 kg. What is the weight of the person who left?',
    opts: ['62 kg', '64 kg', '66 kg', '68 kg'],
    ans: 3,
    exp: 'Total weight of 5 = 5×60 = 300. Total of 4 = 4×58 = 232. Weight of person who left = 300 - 232 = 68 kg.'
  },
  {
    q: 'What is the probability of getting an even number when rolling a fair six-sided die?',
    opts: ['1/6', '1/3', '1/2', '2/3'],
    ans: 2,
    exp: 'Even numbers: 2, 4, 6 (3 outcomes). Total outcomes: 6. Probability = 3/6 = 1/2.'
  },
  {
    q: 'Passage: "Studies show that sleep deprivation impairs cognitive function, particularly memory consolidation and executive control." Which of the following best summarizes the passage?',
    opts: [
      'Sleep is necessary for good health',
      'Lack of sleep affects thinking abilities',
      'Memory is the only thing affected by sleep',
      'Executive control is more important than memory'
    ],
    ans: 1,
    exp: 'The passage specifically links sleep deprivation to cognitive impairment, memory consolidation, and executive control — all thinking abilities.'
  },
  {
    q: 'A shopkeeper sells an item at ₹450 after giving a 10% discount. What was the marked price?',
    opts: ['₹495', '₹500', '₹505', '₹510'],
    ans: 1,
    exp: 'Selling Price = Marked Price × (1 - Discount%). 450 = MP × 0.9. So MP = 450/0.9 = ₹500.'
  }
];
let csatState = { questions: [], index: 0, correct: 0, wrong: 0, xp: 0, answered: false };

function shuffleArray(arr) {
  for (let i = arr.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [arr[i], arr[j]] = [arr[j], arr[i]];
  }
  return arr;
}

function newCSATSet() {
  csatState.questions = shuffleArray([...CSAT_BANK]).slice(0, 10);
  csatState.index = 0;
  csatState.correct = 0;
  csatState.wrong = 0;
  csatState.xp = 0;
  csatState.answered = false;
  loadCSATQuestion();
}

function loadCSATQuestion() {
  const q = csatState.questions[csatState.index];
  if (!q) { newCSATSet(); return; }
  document.getElementById('csatQuestion').textContent = `Q${csatState.index+1}. ${q.q}`;
  const optsDiv = document.getElementById('csatOptions');
  optsDiv.innerHTML = q.opts.map((o, i) =>
    `<button class="csat-option" onclick="selectCSAT(${i})" id="csatOpt${i}">${String.fromCharCode(65+i)}. ${escapeHtml(o)}</button>`
  ).join('');
  document.getElementById('csatResult').innerHTML = '';
  document.getElementById('csatSubmitBtn').style.display = 'inline-block';
  document.getElementById('csatNextBtn').style.display = 'none';
  document.getElementById('csatNum').textContent = `${csatState.index+1}/${csatState.questions.length}`;
  document.getElementById('csatCorrect').textContent = csatState.correct;
  document.getElementById('csatWrong').textContent = csatState.wrong;
  document.getElementById('csatXP').textContent = csatState.xp;
  csatState.answered = false;
}

let selectedCSAT = null;
function selectCSAT(idx) {
  if (csatState.answered) return;
  selectedCSAT = idx;
  document.querySelectorAll('.csat-option').forEach((el, i) => {
    el.classList.toggle('selected', i === idx);
  });
}

function submitCSAT() {
  if (csatState.answered) return;
  if (selectedCSAT === null) {
    showNotification('📝 Select an option first!', 'info');
    return;
  }
  csatState.answered = true;
  const q = csatState.questions[csatState.index];
  const isCorrect = selectedCSAT === q.ans;
  document.querySelectorAll('.csat-option').forEach((el, i) => {
    el.disabled = true;
    if (i === q.ans) el.classList.add('correct');
    else if (i === selectedCSAT && !isCorrect) el.classList.add('wrong');
  });
  if (isCorrect) {
    csatState.correct++;
    csatState.xp += 10;
    awardXP(10);
  } else {
    csatState.wrong++;
  }
  const resultDiv = document.getElementById('csatResult');
  resultDiv.className = `csat-result ${isCorrect ? 'correct' : 'wrong'}`;
  resultDiv.innerHTML = isCorrect
    ? `✅ <strong>Correct!</strong> ${escapeHtml(q.exp)}`
    : `❌ <strong>Wrong.</strong> Correct answer: <strong>${String.fromCharCode(65+q.ans)}</strong>. ${escapeHtml(q.exp)}`;
  document.getElementById('csatSubmitBtn').style.display = 'none';
  document.getElementById('csatNextBtn').style.display = 'inline-block';
  document.getElementById('csatCorrect').textContent = csatState.correct;
  document.getElementById('csatWrong').textContent = csatState.wrong;
  document.getElementById('csatXP').textContent = csatState.xp;
  if (isCorrect) triggerConfetti();
}

function nextCSAT() {
  selectedCSAT = null;
  if (csatState.index < csatState.questions.length - 1) {
    csatState.index++;
    loadCSATQuestion();
  } else {
    // Set complete!
    const pct = Math.round((csatState.correct / csatState.questions.length) * 100);
    const msg = csatState.correct >= 8
      ? `🎉 Excellent! ${pct}% — You crushed it!`
      : csatState.correct >= 5
      ? `👍 Good effort! ${pct}% — Keep practicing!`
      : `💪 Keep going! ${pct}% — Review and try again!`;
    document.getElementById('csatResult').innerHTML =
      `<div style="padding:12px;background:var(--surface);border-radius:var(--radius-sm);text-align:center">
        <h3 style="margin-bottom:8px">${msg}</h3>
        <p style="color:var(--muted);font-size:13px">${csatState.correct}/${csatState.questions.length} correct • ${csatState.xp} XP earned</p>
        <button class="tool-btn primary" style="margin-top:10px" onclick="newCSATSet()">🔄 Practice Again</button>
      </div>`;
    document.getElementById('csatNextBtn').style.display = 'none';
    if (pct >= 80) {
      triggerConfetti();
      setTimeout(triggerConfetti, 1000);
    }
  }
}

// ─── PSYCHOLOGY CONCEPT BANK ───
const PSYCH_CONCEPTS = [
  { concept: 'Classical Conditioning', text: 'Pavlov\'s experiment: A neutral stimulus (bell) is paired with an unconditioned stimulus (food) to elicit a conditioned response (salivation). Key: UCS → UCR, CS → CR. Acquisition, extinction, spontaneous recovery, generalization, discrimination.', tags: ['Learning', 'Behaviorism', 'Pavlov'] },
  { concept: 'Operant Conditioning', text: 'Skinner: Behavior is shaped by consequences. Reinforcement increases behavior (positive = add reward; negative = remove aversive). Punishment decreases behavior. Schedules: fixed/variable ratio/interval. Shaping, chaining, extinction burst.', tags: ['Learning', 'Behaviorism', 'Skinner', 'Reinforcement'] },
  { concept: 'Maslow\'s Hierarchy of Needs', text: 'Pyramid: Physiological → Safety → Love/Belonging → Esteem → Self-Actualization. Later: Self-Transcendence. Lower needs must be substantially met before higher needs motivate. Criticized for cultural bias (individualistic focus).', tags: ['Motivation', 'Humanistic', 'Maslow', 'Personality'] },
  { concept: 'Cognitive Dissonance', text: 'Festinger (1957): Discomfort from holding conflicting cognitions. People are motivated to reduce dissonance by changing beliefs, acquiring new info, or reducing importance. Classic: $1/$20 experiment — insufficient justification leads to attitude change.', tags: ['Social Psychology', 'Attitudes', 'Festinger'] },
  { concept: 'Types of Memory', text: 'Atkinson-Shiffrin Model: Sensory Memory (<1s) → Short-Term Memory (7±2 chunks, ~20s) → Long-Term Memory (unlimited). Working Memory (Baddeley): Central Executive, Phonological Loop, Visuospatial Sketchpad, Episodic Buffer. LTM: Explicit (Semantic/Episodic) vs Implicit (Procedural).', tags: ['Cognition', 'Memory', 'Atkinson-Shiffrin', 'Baddeley'] },
  { concept: 'Heuristics & Biases', text: 'Tversky & Kahneman: Mental shortcuts that lead to systematic errors. Availability Heuristic (ease of recall = frequency). Anchoring (initial value influences judgment). Representativeness (ignoring base rates). Affect Heuristic. Framing effects.', tags: ['Cognition', 'Judgment', 'Kahneman', 'Biases'] },
  { concept: 'Attachment Theory', text: 'Bowlby: Early caregiver bonds shape internal working models. Ainsworth\'s Strange Situation: Secure (distress+recovery), Avoidant (ignore caregiver), Resistant/Ambivalent (clingy+angry), Disorganized (fear+confusion). Affects later relationships.', tags: ['Development', 'Bowlby', 'Ainsworth', 'Social'] },
  { concept: 'Defense Mechanisms', text: 'Freud\'s ego defense mechanisms (unconscious). Anna Freud catalogued them. Key: Repression (blocking), Projection (attributing to others), Rationalization (false reasons), Displacement (redirecting), Sublimation (socially acceptable outlet), Reaction Formation (opposite belief).', tags: ['Psychodynamic', 'Freud', 'Unconscious', 'Ego'] },
  { concept: 'Big Five Personality (OCEAN)', text: 'Five-factor model: Openness (curiosity, imagination), Conscientiousness (discipline, organization), Extraversion (sociability, energy), Agreeableness (cooperation, warmth), Neuroticism (emotional instability). High heritability (~40-60%). Stable across adulthood.', tags: ['Personality', 'Trait Theory', 'OCEAN', 'Assessment'] },
  { concept: 'Neuroplasticity', text: 'Brain\'s ability to reorganize throughout life. Experience-dependent plasticity: synaptic pruning, long-term potentiation (LTP), neurogenesis (hippocampus). Critical periods (language) vs sensitive periods. Key for rehabilitation after brain injury.', tags: ['Biological', 'Brain', 'Development', 'Recovery'] },
  { concept: 'Selye\'s General Adaptation Syndrome', text: 'Three-stage stress response: 1) Alarm (fight-or-flight), 2) Resistance (adaptation, elevated cortisol), 3) Exhaustion (resource depletion, illness). Chronic stress → allostatic load → weakened immune system, hypertension, burnout.', tags: ['Stress', 'Biological', 'Health', 'Selye'] },
  { concept: 'Piaget\'s Cognitive Development', text: 'Four stages: 1) Sensorimotor (0-2yr, object permanence), 2) Preoperational (2-7yr, egocentrism, conservation failure), 3) Concrete Operational (7-11yr, logical thought, conservation), 4) Formal Operational (11+, abstract reasoning, hypothetical thinking).', tags: ['Development', 'Piaget', 'Cognition', 'Stages'] },
  { concept: 'Vygotsky\'s Sociocultural Theory', text: 'Learning through social interaction. Zone of Proximal Development (ZPD): gap between what child can do alone vs with guidance. Scaffolding: support tailored to ZPD. More Knowledgeable Other (MKO). Language as cultural tool.', tags: ['Development', 'Vygotsky', 'Social', 'ZPD'] },
  { concept: 'Milgram\'s Obedience Study', text: 'Participants administered (fake) shocks to a learner when told by authority. 65% went to 450V. Factors: proximity of authority, institutional setting, gradual escalation, agentic shift. Key ethical concerns (deception, psychological distress).', tags: ['Social Psychology', 'Obedience', 'Milgram', 'Ethics'] },
  { concept: 'Weber\'s & Fechner\'s Laws', text: 'Weber\'s Law: Just Noticeable Difference (JND) is proportional to stimulus intensity (ΔI/I = k). Fechner\'s Law: Sensation = k × log(Intensity). Stevens\' Power Law: Sensation = k × I^n (more accurate for most sensory modalities).', tags: ['Sensation', 'Psychophysics', 'Weber', 'Fechner'] },
  { concept: 'Intelligence Theories', text: 'Spearman\'s g (general factor). Thurstone\'s 7 Primary Mental Abilities. Gardner\'s Multiple Intelligences (8 types). Sternberg\'s Triarchic (Analytical, Creative, Practical). Cattell: Fluid (Gf, problem-solving) vs Crystallized (Gc, knowledge). IQ: Mean=100, SD=15.', tags: ['Intelligence', 'Assessment', 'Psychometrics', 'Cognition'] },
  { concept: 'Schizophrenia', text: 'Positive symptoms: hallucinations, delusions, disorganized speech. Negative symptoms: flat affect, avolition, alogia, anhedonia. Cognitive symptoms: attention/memory deficits. Dopamine hypothesis (excess D2 activity). Genetic liability (~50% concordance for MZ twins).', tags: ['Psychopathology', 'Schizophrenia', 'Clinical', 'Treatment'] },
  { concept: 'Kohlberg\'s Moral Development', text: 'Three levels: Pre-conventional (avoid punishment/self-interest), Conventional (social norms/law & order), Post-conventional (social contract/universal ethics). Critiqued for gender bias (Gilligan: ethics of care). Heinz dilemma.', tags: ['Development', 'Morality', 'Kohlberg', 'Gilligan'] },
  { concept: 'Systematic Desensitization', text: 'Wolpe: Behavioral therapy for phobias. Three steps: 1) Relaxation training, 2) Create anxiety hierarchy, 3) Gradual exposure while maintaining relaxation. Based on counterconditioning — incompatible response (relaxation) replaces anxiety. Success rate ~75%+ for specific phobias.', tags: ['Therapy', 'Behavioral', 'Phobia', 'Wolpe'] },
  { concept: 'Yerkes-Dodson Law', text: 'Performance = f(Arousal). Inverted U: moderate arousal = optimal performance. Simple tasks need higher arousal; complex tasks need lower arousal. Anxiety → overarousal → performance decline. Key for stress management and exam preparation strategies.', tags: ['Motivation', 'Arousal', 'Performance', 'Stress'] }
];
let psychIndex = 0;

function loadPsychCard(idx) {
  const c = PSYCH_CONCEPTS[idx];
  document.getElementById('psychConcept').textContent = c.concept;
  document.getElementById('psychText').textContent = c.text;
  document.getElementById('psychTags').innerHTML = c.tags.map(t => `<span>${t}</span>`).join('');
  document.getElementById('psychCounter').textContent = `${idx+1}/${PSYCH_CONCEPTS.length}`;
}

function nextPsych() {
  if (psychIndex < PSYCH_CONCEPTS.length - 1) {
    psychIndex++;
    loadPsychCard(psychIndex);
    // Award small XP for reviewing
    awardXP(2);
  } else {
    showNotification('🎉 You\'ve reviewed all PSYCH concepts! Start again?', 'accent2');
    psychIndex = 0;
    loadPsychCard(0);
  }
}

function prevPsych() {
  if (psychIndex > 0) {
    psychIndex--;
    loadPsychCard(psychIndex);
  }
}

// ─── TUTOR PANEL TOGGLE ───
function toggleTutor(tab) {
  const panel = document.getElementById('tutorPanel');
  panel.classList.toggle('open');
  if (panel.classList.contains('open')) {
    switchTutorTab(tab || 'csat');
    if (tab === 'csat' && (!csatState.questions.length || csatState.index >= csatState.questions.length)) {
      newCSATSet();
    }
    if (tab === 'psych') {
      loadPsychCard(psychIndex);
    }
  }
}

function switchTutorTab(tab) {
  document.querySelectorAll('.tutor-tab').forEach(el => el.classList.remove('active'));
  document.querySelectorAll('.tutor-content').forEach(el => el.classList.remove('active'));
  if (tab === 'csat') {
    document.getElementById('tabCSAT').classList.add('active');
    document.getElementById('tutorCSAT').classList.add('active');
    if (!csatState.questions.length || csatState.index >= csatState.questions.length) {
      newCSATSet();
    } else {
      loadCSATQuestion();
    }
  } else {
    document.getElementById('tabPSYCH').classList.add('active');
    document.getElementById('tutorPSYCH').classList.add('active');
    loadPsychCard(psychIndex);
  }
}

// keyboard shortcut: T for Tutor Panel
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT') return;
  if (e.key === 't' || e.key === 'T') toggleTutor('csat');
});

// Init CSAT on first open
setTimeout(() => { newCSATSet(); loadPsychCard(0); }, 500);

// Keyboard shortcuts
document.addEventListener('keydown', e => {
  if (e.target.tagName === 'INPUT') return;
  if (e.key === 'f' || e.key === 'F') toggleFocusMode();
  if (e.key === 'u' || e.key === 'U') toggleUPSCLens();
  if (e.key === 's' || e.key === 'S') toggleBookmarks();
});
