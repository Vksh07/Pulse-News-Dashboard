{
  "name": "@Vksh07/pulse-news-dashboard",
  "version": "2.0.7",
  "description": "ADHD-Savvy News Dashboard — one-command news reader with UPSC prep, gamification, and ADHD-friendly modes",
  "type": "module",
  "bin": {
    "pulse-news-dashboard": "cli.js"
  },
  "scripts": {
    "start": "node cli.js",
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext ts,tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.101.0",
    "axios": "^1.7.7",
    "chart.js": "^4.4.4",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^11.5.4",
    "idb": "^8.0.0",
    "lucide-react": "^0.441.0",
    "react": "^18.3.1",
    "react-chartjs-2": "^5.2.0",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^6.26.2",
    "tailwind-merge": "^2.5.2",
    "zod": "^3.23.8",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.47.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.8",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.6.0",
    "@typescript-eslint/parser": "^8.6.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.1",
    "@vitest/ui": "^2.1.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.10.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.11",
    "happy-dom": "^15.7.4",
    "jsdom": "^25.0.1",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.10",
    "typescript": "^5.6.2",
    "typescript-eslint": "^8.61.1",
    "vite": "^5.4.5",
    "vitest": "^2.1.1"
  },
  "files": [
    "LICENSE",
    "README.md",
    "cli.js",
    "dist/",
    "eslint.config.js",
    "package.json",
    "postcss.config.js",
    "public/",
    "server.py",
    "src/",
    "static/",
    "tailwind.config.js",
    "tests/",
    "tsconfig.json",
    "tsconfig.node.json",
    "vite.config.ts"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "adhd",
    "news",
    "dashboard",
    "edtech",
    "upsc",
    "productivity",
    "neurodivergent"
  ],
